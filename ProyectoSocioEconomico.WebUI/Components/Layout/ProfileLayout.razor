@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.WebUI.Services
@using System.Security.Claims
@inject CustomAuthenticationStateProvider AuthProvider
@inject IUsuarioService UsuarioService
@inject ICasoService CasoService
@inject NavigationManager Navigation

<div class="page">
    <nav class="bulma-navbar bulma-px-1 bulma-px-5">
        <section class="bulma-navbar-brand">
            <a class="bulma-navbar-item bulma-title" href="/">AidPortal</a>
        </section>
        <section class="bulma-navbar-menu">
            <ul class="bulma-navbar-start">
                <a class="bulma-navbar-item" href="/programs">Programas</a>
                <a class="bulma-navbar-item" href="/about-us">Acerca de nosotros</a>
                <a class="bulma-navbar-item" href="/cases">Casos</a>
                @* <a class="bulma-navbar-item" href="#">Ser volunatario</a> *@
            </ul>
            <section class="bulma-navbar-end bulma-is-flex bulma-is-align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <AuthorizeView Roles="beneficiado" Context="innerContext">
                            <div class="bulma-navbar-item">
                                <a class="bulma-button bulma-is-info">Mi caso</a>
                            </div>
                        </AuthorizeView>
                        <a class="bulma-navbar-item" href="/account/settings">
                            <div class="bulma-is-flex bulma-is-align-items-center">
                                <figure class="bulma-image profile-pic-container bulma-mr-3">
                                    <img class="profile-pic" src="@GetProfileImage(context.User)" alt="Foto de perfil" />
                                </figure>
                                <div class="bulma-is-flex bulma-is-flex-direction-column">
                                    <span class="bulma-has-text-weight-bold" style="line-height: 1.2;">@context.User.Identity?.Name</span>
                                    <span class="bulma-is-size-7 bulma-has-text-grey" style="line-height: 1.2;">@context.User.FindFirst(ClaimTypes.Role)?.Value</span>
                                </div>
                            </div>
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <div class="bulma-navbar-item">
                            <a href="/login" class="bulma-button bulma-is-warning">Registrarse</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </section>
        </section>
    </nav>

    <main>
        <div class="pl-shell">
            <aside class="pl-sidebar">
                <p class="pl-sidebar__heading">SETTINGS MENU</p>

                <nav class="pl-sidebar__nav">
                    <a href="/account/settings" class="@GetNavItemClass("/account/settings")">
                        <span class="bulma-icon bulma-is-small"><i class="far fa-user"></i></span>
                        Ajustes de cuenta
                    </a>

                    <a href="/donor/dashboard" class="@GetNavItemClass("/donor/dashboard")">
                        <span class="bulma-icon bulma-is-small"><i class="fas fa-table-cells-large"></i></span>
                        Mis donaciones
                    </a>

                    @if (IsBeneficiario)
                    {
                        <a href="@MyCaseUrl" class="@GetNavItemClass(MyCaseUrl)">
                            <span class="bulma-icon bulma-is-small"><i class="fa-solid fa-trowel"></i></span>
                            Mi caso
                        </a>

                        <a href="/beneficiary/withdrawals" class="@GetNavItemClass("/beneficiary/withdrawals")">
                            <span class="bulma-icon bulma-is-small"><i class="fas fa-clock-rotate-left"></i></span>
                            Mis retiros
                        </a>
                    }

                    @if (IsAdmin)
                    {
                        @* <a href="" class="@GetNavItemClass("/account/settings")">
                            Perfiles
                        </a> *@

                        <a href="/admin/programs" class="@GetNavItemClass("/admin/programs")">
                            <span class="bulma-icon bulma-is-small"><i class="fa-brands fa-42-group"></i></span>
                            Programas
                        </a>

                        @* <a href="" class="@GetNavItemClass("/beneficiary/withdrawals")">
                            Retiros pendientes
                        </a> *@
                    }
                </nav>
            </aside>

            <section class="pl-content">
                @Body
            </section>
        </div>
    </main>

    <footer class="bulma-footer bulma-has-background-dark bulma-py-6">
        <div class="bulma-container bulma-is-max-desktop">
            <div class="bulma-columns bulma-is-multiline">
                <div class="bulma-column bulma-is-12 bulma-is-6-desktop">
                    <div class="bulma-is-flex bulma-is-align-items-center bulma-mb-3">
                        <h3 class="bulma-title bulma-is-4 bulma-has-text-white">AIDPORTAL</h3>
                    </div>
                    <p class="bulma-has-text-grey-light">
                        Una plataforma socioeconómica dedicada a la transparencia en la ayuda
                        y el apoyo directo a la comunidad. Empoderando personas a través de la acción colectiva.
                    </p>
                    <div class="bulma-is-flex bulma-gap-3 bulma-mt-5">
                        <a href="#" class="bulma-button bulma-is-small bulma-is-dark bulma-is-outlined">
                            <span class="icon"><i class="fab fa-facebook-f"></i></span>
                        </a>
                        <a href="#" class="bulma-button bulma-is-small bulma-is-dark bulma-is-outlined">
                            <span class="icon"><i class="fab fa-instagram"></i></span>
                        </a>
                        <a href="#" class="bulma-button bulma-is-small bulma-is-dark bulma-is-outlined">
                            <span class="icon"><i class="fab fa-twitter"></i></span>
                        </a>
                    </div>
                </div>

                <div class="bulma-column bulma-is-12 bulma-is-3-desktop">
                    <h4 class="bulma-subtitle bulma-is-6 bulma-has-text-white bulma-mb-4">Programas</h4>
                    <ul class="bulma-menu-list">
                        <li><a href="programs?category=salud" class="bulma-has-text-grey-light">Emergencias Médicas</a></li>
                        <li><a href="programs?category=educacion" class="bulma-has-text-grey-light">Fondos Educativos</a></li>
                        <li><a href="programs?category=desastres%20naturales" class="bulma-has-text-grey-light">Ayuda en Desastres</a></li>
                        <li><a href="programs?category=naturaleza" class="bulma-has-text-grey-light">Ayuda en Naturaleza</a></li>
                        <li><a href="programs?category=infraestructura" class="bulma-has-text-grey-light">Ayuda en Infraestructura</a></li>
                    </ul>
                </div>

                <div class="bulma-column bulma-is-12 bulma-is-3-desktop">
                    <h4 class="bulma-subtitle bulma-is-6 bulma-has-text-white bulma-mb-4">Organización</h4>
                    <ul class="bulma-menu-list">
                        <li><a href="/about-us" class="bulma-has-text-grey-light">Acerca de Nosotros</a></li>
                        <li><a href="/cases" class="bulma-has-text-grey-light">Casos</a></li>
                        @* <li><a href="#" class="bulma-has-text-grey-light">Ser Voluntario</a></li> *@
                        <li><a href="/programs" class="bulma-has-text-grey-light">Programas</a></li>
                    </ul>
                </div>
            </div>

            <hr class="bulma-has-background-grey-dark bulma-my-5">

            <div class="bulma-level bulma-is-mobile">
                <div class="bulma-level-left">
                    <div class="bulma-level-item">
                        <p class="bulma-has-text-grey-light bulma-is-size-7">
                            © 2026 Aid & Donation Portal. Todos los derechos reservados.
                        </p>
                    </div>
                </div>
                <div class="bulma-level-right">
                    <div class="bulma-level-item">
                        <p class="bulma-has-text-grey-light bulma-is-size-7">
                            Hecho con amor para la comunidad
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>
</div>

@code {
    private Usuario? CurrentUser { get; set; }
    private bool IsBeneficiario { get; set; }
    private bool IsAdmin { get; set; }
    private string MyCaseUrl { get; set; } = "/cases/new/step1";

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        CurrentUser = null;
        IsBeneficiario = false;
        IsAdmin = false;
        MyCaseUrl = "/cases/new/step1";

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            return;
        }

        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdStr, out var userId))
        {
            return;
        }

        CurrentUser = await UsuarioService.ObtenerPorId(userId);
        IsBeneficiario = HasBeneficiaryRole(CurrentUser);
        IsAdmin = HasAdminRole(CurrentUser);

        if (!IsBeneficiario)
        {
            return;
        }

        var casoUsuario = await CasoService.ObtenerPorBeneficiadoIdAsync(userId);
        MyCaseUrl = casoUsuario is null ? "/cases/new/step1" : "/beneficiary/dashboard";
    }

    private static bool HasBeneficiaryRole(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               (roleName.Equals("Beneficiario", StringComparison.OrdinalIgnoreCase) ||
                roleName.Equals("Beneficiado", StringComparison.OrdinalIgnoreCase));
    }

    private static bool HasAdminRole(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               roleName.Equals("Administrador", StringComparison.OrdinalIgnoreCase);
    }

    private string GetProfileImage(ClaimsPrincipal user)
    {
        var imagePath = user.FindFirst("ImagenPerfil")?.Value;
        if (string.IsNullOrEmpty(imagePath))
        {
            return "/uploads/profiles/DefaultProfile.png";
        }

        return imagePath.StartsWith("/") ? imagePath : "/" + imagePath;
    }

    private string GetNavItemClass(string href)
    {
        var currentPath = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        var normalizedHref = string.IsNullOrWhiteSpace(href) ? "/" : href;

        if (string.Equals(currentPath, normalizedHref, StringComparison.OrdinalIgnoreCase))
        {
            return "pl-sidebar__nav-item pl-sidebar__nav-item--active";
        }

        return "pl-sidebar__nav-item";
    }
}
