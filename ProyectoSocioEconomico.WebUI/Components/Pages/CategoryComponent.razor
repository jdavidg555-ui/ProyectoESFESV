@*
  CategoryComponent.razor
  Propósito: Ícono/tarjeta representando una categoría con contador de casos activos.
  Recupera el conteo de casos desde la base de datos en OnInitializedAsync.
*@
<article class="icon-category">
    <a class="icon-category__link" href="@Href">
        <div class="icon-category__circle">
            <span class="bulma-icon">
                <i class="fa-solid @Icon icon-category__icon @ColorClass"></i>
            </span>
        </div>
        <h2 class="icon-category__title bulma-has-text-centered">@Title</h2>
        <p class="bulma-has-text-centered">@Cases casos activos</p>
    </a>
</article>

@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Infrastructure.Data

@code {
    [Parameter]
    public string? Icon { set; get; }
    [Parameter]
    public string? Title { set; get; }
    [Parameter]
    public string? ColorClass { set; get; }
    [Parameter]
    public int IdCategoria { get; set; }
    [Parameter]
    public string Href { get; set; } = "/programs";

    public string? Cases { set; get; }

    @inject IDbContextFactory<AppDbContext> DbContextFactory

    protected override async Task OnInitializedAsync()
    {
        await using var dbContext = await DbContextFactory.CreateDbContextAsync();

        var count = await dbContext.Casos
            .Where(c => c.IdCategoria == IdCategoria && (c.Estado == "Activo" || c.Estado == "Pendiente"))
            .CountAsync();

        Cases = count.ToString();
    }
}
