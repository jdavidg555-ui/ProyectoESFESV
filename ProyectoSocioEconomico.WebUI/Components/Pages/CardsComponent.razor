@using System.Globalization
@using ProyectoSocioEconomico.Application.Interfaces
@inject ICasoService CasoService

<section class="bulma-section">
    <div class="bulma-container">
        @if (casos.Count == 0)
        {
            <div class="bulma-notification bulma-is-light">
                <p class="bulma-has-text-grey">No hay casos disponibles por el momento.</p>
            </div>
        }
        else
        {
            <div class="bulma-columns bulma-is-multiline">
                @foreach (var caso in casos)
                {
                    decimal totalRecaudado = 0m;
                    if (caso.Donaciones != null)
                    {
                        foreach (var donacion in caso.Donaciones)
                        {
                            totalRecaudado += donacion.Monto;
                        }
                    }

                    <div class="bulma-column bulma-is-3-desktop bulma-is-6-tablet">
                        <CardComponent Title="@caso.Titulo"
                                       Description="@caso.Descripcion"
                                       MoneyRaised="@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))"
                                       RemainingPercentage="@CalcularPorcentajeProgreso(caso.Meta, totalRecaudado)"
                                       ImageUrl="@caso.ImagenUrl" />
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private List<dynamic> casos = new();

    protected override async Task OnInitializedAsync()
    {
        casos = (await CasoService.ObtenerActivosParaHome(4)).Cast<dynamic>().ToList();
    }

    private static int CalcularPorcentajeProgreso(decimal meta, decimal totalRecaudado)
    {
        if (meta <= 0)
        {
            return 0;
        }

        var porcentaje = (int)Math.Round((totalRecaudado / meta) * 100, MidpointRounding.AwayFromZero);

        return Math.Clamp(porcentaje, 0, 100);
    }
}
