@namespace ProyectoSocioEconomico.WebUI.Components.Pages
@*
  BeneficiaryCaseDashboard.razor
  Propósito: Dashboard del beneficiario que muestra casos, métricas y accesos rápidos para gestionar su campaña.
*@
@page "/beneficiary/dashboard"
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Application.Interfaces
@inject ICasoService CasoService
@inject NavigationManager Navigation

<div class="bcd-page">
    <div class="bcd-header">
        <h1 class="bcd-title">Mi Panel de Casos</h1>
        <p class="bcd-subtitle">Administra tus campañas y revisa el estado de las donaciones</p>
    </div>

    <div class="bcd-content">
        <div class="bcd-list">
            @if (Cases == null)
            {
                <p>Cargando...</p>
            }
            else if (!Cases.Any())
            {
                <p>No tienes campañas activas.</p>
            }
            else
            {
                @foreach (var c in Cases)
                {
                    <div class="bcd-item">
                        <h3>@c.Titulo</h3>
                        <p>@c.Descripcion</p>
                        <a href="/cases/@c.Id/edit" class="bulma-button bulma-is-light">Editar</a>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<Caso>? Cases;

    protected override async Task OnInitializedAsync()
    {
        Cases = await CasoService.ObtenerPorBeneficiadoAsync();
    }
}
