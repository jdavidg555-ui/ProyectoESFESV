@*
  Home.razor
  Propósito: Página principal (home) de la aplicación. Contiene el buscador, la sección
  "Explorar categorias" y renderiza componentes de resumen (CardsComponent). También
  muestra un diálogo cuando el usuario intenta crear un caso duplicado.
*@
@page "/"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Navigation

<dialog class="home-duplicate-dialog" @attributes="DialogAttributes" aria-labelledby="duplicate-case-title">
    <article class="home-duplicate-dialog__card">
        <div class="home-duplicate-dialog__icon" aria-hidden="true">
            <i class="fa-solid fa-circle-exclamation"></i>
        </div>
        <p class="home-duplicate-dialog__eyebrow">Caso ya registrado</p>
        <h2 id="duplicate-case-title" class="home-duplicate-dialog__title">Solo puedes crear un caso por persona</h2>
        <p class="home-duplicate-dialog__body">
            Ya tienes un caso registrado en la plataforma. Si necesitas cambios, debes revisar ese caso actual.
        </p>
        <div class="home-duplicate-dialog__actions">
            <button type="button" class="bulma-button bulma-is-warning home-duplicate-dialog__button"
                    @onclick="CloseDuplicateCaseDialog">
                Entendido
            </button>
        </div>
    </article>
</dialog>

<PageTitle>Home</PageTitle>

<header class="header">
    <section class="header__container">
        <h1 class="header__title">Conectamos apoyo solidario con quienes <span class="header__title--primary-color">mas
            lo necesitan</span></h1>
            <p class="header__subtitle">Unete a la comunidad y marca la diferencia cada pequeña accion
                salva vidas</p>
                <div class="search">
                    <div class="bulma-control bulma-has-icons-left search__input-container">
                        <input class="bulma-input bulma-input-rounded bulma-is-success bulma-is-medium search__input"
                               type="text" name="search" placeholder="Busca casos" @bind="searchQuery" @bind:event="oninput"
                               @onkeydown="HandleSearchKeyDown" />
                        <span class="bulma-icon bulma-is-small bulma-is-left">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </span>
                    </div>
                    <button type="button" class="bulma-button bulma-is-success" @onclick="NavigateToCasesSearch">Encuentra un
                        caso</button>
                    </div>
                </section>
            </header>

            <section class="bulma-container bulma-mt-5">
                <section class="bulma-section">
                    <div class="bulma-is-flex bulma-is-justify-content-space-between">
                        <div>Explorar categorias</div>
                        <a class="color-primary" href="/programs">Ver mas</a>
                    </div>
                    <section class="bulma-section icons-container">
                        <CategoryComponent @key="4" Title="Salud" IdCategoria="4" Href="/cases?category=salud" Icon="fa-heart-pulse" ColorClass="icon-category__icon--health" />
                        <CategoryComponent @key="3" Title="Educacion" IdCategoria="3" Href="/cases?category=educacion" Icon="fa-book-open" ColorClass="icon-category__icon--education" />
                        <CategoryComponent @key="1" Title="Infraestructura" IdCategoria="1" Href="/cases?category=infraestructura" Icon="fa-wrench" ColorClass="icon-category__icon--infrastructure" />
                        <CategoryComponent @key="5" Title="Desastres naturales" Icon="fa-person-walking-arrow-loop-left"
                                           IdCategoria="5" Href="/cases?category=desastres%20naturales"
                                           ColorClass="icon-category__icon--disaster-relief" />
                        <CategoryComponent @key="2" Title="Naturaleza" IdCategoria="2" Href="/cases?category=naturaleza" Icon="fa-leaf" ColorClass="icon-category__icon--environment" />
                    </section>
                    <section
                        class="bulma-section bulma-is-flex bulma-is-justify-content-space-between bg-cream-color section-redondeado">
                        <div class="mx-3">
                            <h2 class="bulma-has-text-black bulma-title">Buscando apoyo?</h2>
                            <p class="bulma-has-text-black">Ya sean facturas médicas, proyectos comunitarios o necesidades
                                educativas,
                                Nuestra plataforma lo conecta directamente con quienes se preocupan. Comienza tu
                                campaña en menos de 5 minutos.</p>
                            </div>
                            <div class="bulma-is-flex bulma-is-align-items-center">
                                <a class="bulma-button bulma-is-success bulma-is-medium" href="/cases/new/step1">Crea tu caso ahora</a>
                            </div>
                        </section>
                    </section>
                </section>
                <div class="bulma-container">
                    <section class="bulma-section bulma-is-flex bulma-is-align-items-center">
                        <div class="raya-decoration"></div>
                        <p class="bulma-has-text-black mx-3">Programas activos de Aid</p>
                    </section>

                    <CardsComponent />
                </div>

@code {
    [SupplyParameterFromQuery(Name = "caseWarning")]
    private string? caseWarning { get; set; }

    private bool showDuplicateCaseDialog;
    private string searchQuery = string.Empty;

    protected override void OnParametersSet()
    {
        showDuplicateCaseDialog = caseWarning == "duplicate";
    }

    private void CloseDuplicateCaseDialog()
    {
        showDuplicateCaseDialog = false;
        Navigation.NavigateTo("/", replace: true);
    }

    private void NavigateToCasesSearch()
    {
        var normalizedQuery = searchQuery.Trim();

        if (string.IsNullOrWhiteSpace(normalizedQuery))
        {
            Navigation.NavigateTo("/cases");
            return;
        }

        Navigation.NavigateTo($"/cases?q={Uri.EscapeDataString(normalizedQuery)}");
    }

    private void HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            NavigateToCasesSearch();
        }
    }

    private IReadOnlyDictionary<string, object> DialogAttributes =>
        showDuplicateCaseDialog ? new Dictionary<string, object> { ["open"] = true } : new Dictionary<string, object>();
}
