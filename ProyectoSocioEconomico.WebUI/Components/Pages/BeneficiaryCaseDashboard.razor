@page "/beneficiary/dashboard"
@layout ProfileLayout
@rendermode InteractiveServer
@using ProyectoSocioEconomico.WebUI.Services
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject CustomAuthenticationStateProvider AuthProvider
@inject ICasoService CasoService
@inject IUsuarioService UsuarioService
@inject IRetiroService RetiroService
@inject NavigationManager Navigation

<div class="bw-page">
    <main class="bw-main">
        @if (CurrentCase == null)
        {
            <div class="bw-main__header">
                <h1 class="bw-main__title">Cargando...</h1>
            </div>
        }
        else
        {
            <div class="bw-main__header">
                <div>
                    <h1 class="bw-main__title">@CurrentCase.Titulo</h1>
                    <p class="bw-main__subtitle">Panel de gestión de fondos y estadísticas</p>
                </div>
                <a href="/cases/edit/@CurrentCase.Id" class="bw-btn-edit">
                    <i class="fas fa-pen-to-square"></i> Editar Caso
                </a>
            </div>

            <!-- ── ESTADÍSTICAS ── -->
            <div class="bw-stats-grid">
                <div class="bw-stat-card">
                    <span class="bw-stat-card__label">RECAUDADO</span>
                    <span class="bw-stat-card__value">@TotalRecaudado.ToString("C")</span>
                </div>
                <div class="bw-stat-card">
                    <span class="bw-stat-card__label">DISPONIBLE</span>
                    <span class="bw-stat-card__value" style="color: var(--bw-green);">@BalanceDisponible.ToString("C")</span>
                </div>
                <div class="bw-stat-card">
                    <span class="bw-stat-card__label">META TOTAL</span>
                    <span class="bw-stat-card__value">@CurrentCase.Meta.ToString("C")</span>
                </div>
            </div>

            <!-- ── GESTIÓN DE RETIRO ── -->
            <section class="bw-card">
                <h2 class="bw-section-title">
                    <i class="fas fa-hand-holding-dollar" style="color: var(--bw-green);"></i>
                    Solicitar Retiro de Fondos
                </h2>

                <p class="mb-4" style="color: #666; font-size: 0.95rem;">
                    Seleccione su método de pago preferido e ingrese el monto que desea retirar de su balance disponible.
                </p>

                <!-- Método de Pago -->
                <div class="bw-methods-grid">
                    <button type="button" 
                            class="bw-method-card @(SelectedMethod == "bank" ? "bw-method-card--selected" : "")"
                            @onclick='() => SelectedMethod = "bank"'>
                        <div class="bw-method-icon"><i class="fas fa-building-columns"></i></div>
                        <div>
                            <div class="bw-method-title">Transferencia Bancaria</div>
                            <div style="font-size: 0.8rem; color: #777;">Depósito directo a cuenta</div>
                        </div>
                    </button>

                    <button type="button" 
                            class="bw-method-card @(SelectedMethod == "wallet" ? "bw-method-card--selected" : "")"
                            @onclick='() => SelectedMethod = "wallet"'>
                        <div class="bw-method-icon"><i class="fas fa-credit-card"></i></div>
                        <div>
                            <div class="bw-method-title">Billetera Digital</div>
                            <div style="font-size: 0.8rem; color: #777;">Chivo, MoMo, etc.</div>
                        </div>
                    </button>
                </div>

                <!-- Formulario Dinámico -->
                <div class="bw-form mb-5">
                    @if (SelectedMethod == "bank")
                    {
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div class="bw-field">
                                <label class="bw-label">Nombre del Banco</label>
                                <input class="bw-input" type="text" @bind="BankName" placeholder="Ej. Banco Agrícola" />
                            </div>
                            <div class="bw-field">
                                <label class="bw-label">Número de Cuenta</label>
                                <input class="bw-input" type="text" @bind="AccountNumber" placeholder="000-000-0000" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div class="bw-field">
                                <label class="bw-label">Tipo de Billetera</label>
                                <input class="bw-input" type="text" @bind="BankName" placeholder="Ej. Chivo Wallet" />
                            </div>
                            <div class="bw-field">
                                <label class="bw-label">Número de Teléfono</label>
                                <input class="bw-input" type="text" @bind="AccountNumber" placeholder="7777-7777" />
                            </div>
                        </div>
                    }

                    <div class="bw-field" style="max-width: 300px;">
                        <label class="bw-label">Monto a Retirar</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); font-weight: 700; color: #555;">$</span>
                            <input class="bw-input" type="number" step="0.01" @bind="WithdrawAmount" style="padding-left: 2rem;" />
                        </div>
                        <p style="font-size: 0.75rem; color: #888;">Máximo disponible: @BalanceDisponible.ToString("C")</p>
                    </div>
                </div>

                <!-- Acciones -->
                <div class="bw-actions">
                    <button class="bw-btn-withdraw" @onclick="HandleWithdraw">
                        <i class="fas fa-circle-check"></i>
                        Confirmar y Retirar
                    </button>
                    <a href="/beneficiary/withdrawals" class="bw-btn-history">
                        <i class="fas fa-clock-rotate-left"></i>
                        Historial de Retiros
                    </a>
                </div>
            </section>
        }
    </main>

    <!-- ── MODAL FEEDBACK ── -->
    @if (ShowModal)
    {
        <div class="bw-modal">
            <div class="bw-modal-content">
                <div class="bw-modal-icon">
                    @if (IsSuccess)
                    {
                        <i class="fas fa-circle-check" style="color: var(--bw-green);"></i>
                    }
                    else
                    {
                        <i class="fas fa-circle-xmark" style="color: #ef4444;"></i>
                    }
                </div>
                <h3 class="bw-modal-title">@(IsSuccess ? "¡Solicitud Exitosa!" : "Hubo un Problema")</h3>
                <p class="bw-modal-text">@ModalMessage</p>
                <button class="bw-modal-btn" @onclick="() => ShowModal = false">Entendido</button>
            </div>
        </div>
    }
</div>

@code {
    private Usuario? CurrentUser { get; set; }
    private Caso? CurrentCase { get; set; }
    
    private decimal TotalRecaudado { get; set; }
    private decimal BalanceDisponible { get; set; }
    
    // Form fields
    private string SelectedMethod { get; set; } = "bank";
    private string BankName { get; set; } = "";
    private string AccountNumber { get; set; } = "";
    private decimal WithdrawAmount { get; set; }

    // Modal state
    private bool ShowModal { get; set; }
    private bool IsSuccess { get; set; }
    private string ModalMessage { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out int userId))
            {
                CurrentUser = await UsuarioService.ObtenerPorId(userId);
                if (CurrentUser != null)
                {
                    CurrentCase = await CasoService.ObtenerPorBeneficiadoIdAsync(userId);
                    if (CurrentCase != null)
                    {
                        await LoadStats();
                    }
                    else
                    {
                        // No tiene caso, redirigir o mostrar mensaje
                        Navigation.NavigateTo("/cases/new/step1");
                    }
                }
            }
        }

        if (CurrentUser == null)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task LoadStats()
    {
        if (CurrentCase == null) return;
        
        TotalRecaudado = CurrentCase.Donaciones
            .Where(d => d.Estado == "Completado")
            .Sum(d => d.Monto);
            
        BalanceDisponible = await RetiroService.ObtenerBalanceDisponibleAsync(CurrentCase.Id);
    }

    private async Task HandleWithdraw()
    {
        if (CurrentCase == null || CurrentUser == null) return;

        if (WithdrawAmount <= 0)
        {
            ShowFeedback(false, "Por favor, ingrese un monto válido mayor a cero.");
            return;
        }

        if (WithdrawAmount > BalanceDisponible)
        {
            ShowFeedback(false, "El monto excede su balance disponible.");
            return;
        }

        if (string.IsNullOrWhiteSpace(BankName) || string.IsNullOrWhiteSpace(AccountNumber))
        {
            ShowFeedback(false, "Por favor, complete todos los datos del método de pago.");
            return;
        }

        try
        {
            var nuevoRetiro = new Retiro
            {
                IdBeneficiado = CurrentUser.Id,
                IdCaso = CurrentCase.Id,
                Monto = WithdrawAmount,
                MetodoPago = SelectedMethod == "bank" ? "Transferencia Bancaria" : "Billetera Digital",
                DatosPago = $"{BankName} - {AccountNumber}",
                Estado = "Pendiente",
                FechaSolicitud = DateTime.Now
            };

            await RetiroService.Crear(nuevoRetiro);
            
            await LoadStats();
            
            ShowFeedback(true, $"Su solicitud de retiro por {WithdrawAmount:C} ha sido enviada correctamente. Se procesará en un plazo de 24-48 horas.");
            
            // Clear amount
            WithdrawAmount = 0;
        }
        catch (Exception ex)
        {
            ShowFeedback(false, "Error al procesar el retiro: " + ex.Message);
        }
    }

    private void ShowFeedback(bool success, string message)
    {
        IsSuccess = success;
        ModalMessage = message;
        ShowModal = true;
    }
}
