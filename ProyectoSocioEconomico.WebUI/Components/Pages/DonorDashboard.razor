@page "/donor/dashboard"
@using ProyectoSocioEconomico.WebUI.Services
@inject CustomAuthenticationStateProvider AuthProvider

<div class="dp-page">


    <!-- ═══════════════ BODY ═══════════════ -->
    <div class="dp-body">

        <!-- ── SIDEBAR ── -->
        <aside class="dp-sidebar">
            <p class="dp-sidebar__heading">SETTINGS MENU</p>

            <!-- Nav links -->
            <nav class="dp-sidebar__nav">
                <a href="/account/settings" class="dp-sidebar__nav-item">
                    <span class="bulma-icon bulma-is-small"><i class="far fa-user"></i></span>
                    Account Settings
                </a>
                <a href="/donor/dashboard" class="dp-sidebar__nav-item dp-sidebar__nav-item--active">
                    <span class="bulma-icon bulma-is-small"><i class="fas fa-table-cells-large"></i></span>
                    Mis donaciones
                </a>
            </nav>
        </aside>

        <!-- ── MAIN CONTENT ── -->
        <main class="dp-main">

            <!-- Page header -->
            <div class="dp-main__header">
                <div class="dp-main__header-text">
                    <h1 class="dp-main__title">Mis donaciones</h1>
                </div>
            </div>

            <!-- Stat cards -->
            <div class="dp-stats-grid">

                <div class="dp-stat-card">
                    <span class="dp-stat-card__icon-wrap dp-stat-card__icon-wrap--yellow">
                        <i class="fas fa-hand-holding-dollar"></i>
                    </span>
                    <div class="dp-stat-card__body">
                        <p class="dp-stat-card__label">TOTAL DONADO</p>
                        <p class="dp-stat-card__value">$12,450.00</p>
                    </div>
                </div>

                <div class="dp-stat-card">
                    <span class="dp-stat-card__icon-wrap dp-stat-card__icon-wrap--green">
                        <i class="fas fa-people-group"></i>
                    </span>
                    <div class="dp-stat-card__body">
                        <p class="dp-stat-card__label">CASOS APOYADOS</p>
                        <p class="dp-stat-card__value">142</p>
                        <p class="dp-stat-card__sub">Casos en los que has ayudado</p>
                    </div>
                </div>

            </div>

            <!-- Donation History -->
            <div class="dp-history-card">
                <div class="dp-history-card__header">
                    <h2 class="dp-history-card__title">
                        <span class="bulma-icon bulma-is-small"><i class="fas fa-clock-rotate-left"></i></span>
                        Historial de Donaciones
                    </h2>
                    <a href="/donor/transactions" class="dp-history-card__view-all">Ver todas las transacciones</a>
                </div>

                <table class="bulma-table dp-history-table bulma-is-fullwidth">
                    <thead>
                        <tr>
                            <th class="dp-history-table__th">RECEPTOR (CASO/PROGRAMA)</th>
                            <th class="dp-history-table__th dp-history-table__th--right">CANTIDAD</th>
                            <th class="dp-history-table__th"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var donation in Donations)
                        {
                            <tr class="dp-history-table__row">
                                <td class="dp-history-table__td">
                                    <p class="dp-history-table__recipient">@donation.Name</p>
                                    <p class="dp-history-table__type">@donation.Type</p>
                                </td>
                                <td class="dp-history-table__td dp-history-table__td--amount">
                                    @donation.Amount.ToString("C")
                                </td>
                                <td class="dp-history-table__td dp-history-table__td--badge">
                                    <span class="dp-badge dp-badge--yellow"></span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

@code {
    private string userName = "Cargando...";
    private string userImage = "https://i.pravatar.cc/40?img=12";
    private record DonationRecord(string Name, string Type, decimal Amount);

    private List<DonationRecord> Donations = new()
    {
        new("Education Fund: Northern District", "Institutional Program", 1200m),
        new("Medical Relief: Case #8821",        "Direct Case Aid",       450m),
        new("Rural Development Initiative",       "Institutional Program", 2500m),
        new("Emergency Relief: San Salvador",     "Disaster Recovery",     800m),
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            userName = user.Identity.Name ?? "Usuario";
            userImage = user.FindFirst("ImagenPerfil")?.Value ?? "https://i.pravatar.cc/40?img=12";
        }
    }
}
