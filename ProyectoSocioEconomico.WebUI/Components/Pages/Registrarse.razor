@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Infrastructure.Data
@using ProyectoSocioEconomico.WebUI.Services
@inject IUsuarioService UsuarioService
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager
@inject CustomAuthenticationStateProvider CustomAuthStateProvider

<section class="bulma-section registrarse bulma-is-fullheight bulma-has-background-white-bis">
    <div class="bulma-container">
        <div class="bulma-columns bulma-is-centered">
            <div class="bulma-column registrarse-column">
                <form @onsubmit="ManejarLogin" class="bulma-box bulma-p-6 bulma-has-background-white form-registrarse">
                <div class="login-step3-content bulma-has-text-black">
                <div class="login-step3-text">
                    <h1 class="bulma-title bulma-has-text-black bulma-mb-5">Bienvenido de vuelta</h1>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensaje))
                {
                    <div class="bulma-notification @(esError ? "bulma-is-danger" : "bulma-is-success") bulma-mb-4">
                        @mensaje
                    </div>
                }

                <section class="login-step3-inputs-grid">
                    <div class="bulma-field bulma-mb-0">
                        <label class="bulma-label bulma-has-text-black">Correo electrónico</label>
                        <div class="bulma-control bulma-has-icons-left">
                            <span class="bulma-icon bulma-is-small bulma-is-left">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input class="bulma-input bulma-is-medium" type="email" name="email"
                                   placeholder="ejemplo@gmail.com" @bind="email" />
                        </div>
                    </div>
                    
                    <div class="bulma-field bulma-mb-0">
                        <label class="bulma-label bulma-has-text-black">Contraseña</label>
                        <div class="bulma-control bulma-has-icons-right bulma-has-icons-left">
                            <span class="bulma-icon bulma-is-small bulma-is-left">
                                <i class="fa-solid fa-key"></i>
                            </span>
                            <input class="bulma-input bulma-is-medium" type="@(verPassword ? "text" : "password")"
                                   name="password" placeholder="Mínimo 8 caracteres" @bind="password" />
                            <span class="bulma-icon bulma-is-small bulma-is-right bulma-is-clickable" @onclick="TogglePassword">
                                <i class="fa-solid @(verPassword ? "fa-eye" : "fa-eye-slash")"></i>
                            </span>
                        </div>
                    </div>
                </section>
                <div class="bulma-field field-terminos">
                    <label class="bulma-checkbox">
                        <input type="checkbox" class="bulma-mr-5" @bind="aceptaTerminos" />
                        <span class="bulma-has-text-black">
                            Acepto los términos de servicio y la política de privacidad.
                        </span>
                    </label>
                </div>
                <button type="submit" class="bulma-button bulma-is-warning bulma-is-fullwidth" disabled="@guardando">
                    @(guardando ? "Ingresando..." : "Iniciar Sesión")
                </button>
                <hr />
                <p class="bulma-has-text-centered bulma-has-text-grey-darker">
                    ¿No tienes una cuenta? 
                    <a href="/registrarse" class="a-crear-cuenta">Crear cuenta</a>
                </p>
                </div>
                </form>
            </div>
        </div>
    </div>
</section>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool aceptaTerminos;
    private bool guardando;
    private string mensaje = string.Empty;
    private bool esError;
    private bool verPassword;

    private void TogglePassword() => verPassword = !verPassword;

    private async Task ManejarLogin()
    {
        mensaje = string.Empty;
        esError = false;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            esError = true;
            mensaje = "Completa todos los campos.";
            return;
        }

        if (password.Length < 8)
        {
            esError = true;
            mensaje = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        if (!aceptaTerminos)
        {
            esError = true;
            mensaje = "Debes aceptar los términos y condiciones para continuar.";
            return;
        }

        guardando = true;

        try
        {
            var usuarios = await UsuarioService.ObtenerTodos();
            var usuarioEncontrado = usuarios.FirstOrDefault(u => 
                u.Email.Equals(email.Trim(), StringComparison.OrdinalIgnoreCase) && 
                u.PasswordHash == password);

            if (usuarioEncontrado != null)
            {
                mensaje = "Sesión iniciada correctamente.";
                esError = false;
                CustomAuthStateProvider.NotifyUserLogin(usuarioEncontrado);
                NavigationManager.NavigateTo("/");
            }
            else
            {
                esError = true;
                mensaje = "Correo electrónico o contraseña incorrectos.";
            }
        }
        catch
        {
            esError = true;
            mensaje = "Ocurrió un error al intentar iniciar sesión.";
        }
        finally
        {
            guardando = false;
        }
    }
}
