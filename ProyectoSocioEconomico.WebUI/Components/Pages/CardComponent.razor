
@using Microsoft.AspNetCore.Components

<div class="bulma-card card-custom">

    <!-- Imagen -->
    <div class="bulma-card-image">
        <figure class="bulma-image">
            @if (!string.IsNullOrEmpty(ImageUrl))
            {
                <img src="@ImageUrl" alt="@Title" />
            }
            else
            {
                <img src="https://bulma.io/assets/images/placeholders/1280x960.png" alt="Placeholder" />
            }
        </figure>
    </div>

    <!-- Contenido -->
    <div class="bulma-card-content">
        <p class="bulma-title bulma-is-4 title-custom">@Title</p>

        <div class="bulma-content description-custom">
            @Description
        </div>

        <!-- Sección de progreso -->
        <div class="progress-container">
            <div class="bulma-is-flex bulma-is-justify-content-space-between bulma-mb-2">
                <span class="bulma-has-text-weight-semibold">Recaudado:</span>
                <span class="bulma-has-text-success bulma-has-text-weight-bold">@MoneyRaised</span>
            </div>
            <progress class="bulma-progress bulma-is-success" 
                      value="@RemainingPercentage" 
                      max="100">@RemainingPercentage%</progress>
        </div>
    </div>

    <!-- Footer con botón -->
    <footer class="bulma-card-footer">
        <button class="bulma-card-footer-item bulma-button btn-donate">
            Dona ahora
        </button>
    </footer>

</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string MoneyRaised { get; set; } = string.Empty;
    [Parameter] public int RemainingPercentage { get; set; }
    [Parameter] public string ImageUrl { get; set; } = string.Empty;
}
