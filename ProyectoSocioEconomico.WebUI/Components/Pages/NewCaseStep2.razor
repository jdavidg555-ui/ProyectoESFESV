@* NewCaseStep2.razor *@
@page "/cases/new/step2"
@rendermode InteractiveServer
@using ProyectoSocioEconomico.WebUI.Services
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject NewCaseState CaseState
@inject ICasoService CasoService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment Environment
@inject IJSRuntime JSRuntime
@using System.IO
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="newcasestep2-page">
    <EditForm Model="CaseState" OnValidSubmit="OnSubmitClicked" OnInvalidSubmit="OnInvalidSubmit" FormName="NewCaseStep2Form">
        <DataAnnotationsValidator />
        <div class="newcasestep2__container">
            @if (!string.IsNullOrWhiteSpace(submissionError))
            {
                <div class="bulma-notification bulma-is-danger bulma-is-light newcasestep2__feedback">
                    @submissionError
                </div>
            }

            @if (validationMessages.Any())
            {
                <div class="bulma-notification bulma-is-danger bulma-is-light newcasestep2__feedback">
                    <p class="has-text-weight-semibold">Revisa estos campos antes de continuar:</p>
                    <ul class="newcasestep2__feedback-list">
                        @foreach (var message in validationMessages)
                        {
                            <li>@message</li>
                        }
                    </ul>
                </div>
            }
            
            @* BARRA DE PROGRESO *@
            <div class="newcasestep2__progress-section">
                <div class="newcasestep2__progress-header">
                    <span class="newcasestep2__step-label">100% COMPLETADO</span>
                </div>
                <progress class="bulma-progress newcasestep2__progress-bar" value="100" max="100"></progress>
            </div>

            @* ENCABEZADO *@
            <div class="newcasestep2__heading-block">
                <h1 class="newcasestep2__title">Finalizar Campaña</h1>
                <p class="newcasestep2__subtitle">Detalles de verificación y desembolso</p>
            </div>

            <div class="newcasestep2__content">

                @* EVIDENCIA DE RESPALDO *@
                <div class="newcasestep2__section">
                    <div class="newcasestep2__section-header">
                        <span class="newcasestep2__section-icon"><i class="fas fa-shield-halved"></i></span>
                        <h2 class="newcasestep2__section-title">Evidencia de Respaldo</h2>
                    </div>
                    <p class="newcasestep2__section-description">
                        Para garantizar la transparencia y generar confianza con los donantes, cargue documentos oficiales como facturas médicas, 
                        recetas o estados de cuenta de servicios públicos. Formatos aceptados: PDF, JPG, PNG.
                    </p>

                    @* Arrastrar y Soltar / Seleccionar Archivos *@
                    <label class="newcasestep2__upload-area">
                        <div class="newcasestep2__dropzone">
                            <div class="newcasestep2__cloud-icon"><i class="fas fa-cloud-arrow-up"></i></div>
                            <p class="newcasestep2__drop-text">Arrastra y suelta archivos aquí</p>
                            <p class="newcasestep2__drop-text">o haz clic para buscar en tu computadora</p>
                            <span class="bulma-button bulma-is-dark newcasestep2__select-btn">
                                Seleccionar Archivos
                            </span>
                        </div>
                        <InputFile OnChange="HandleEvidenceFiles" class="newcasestep2__file-input" multiple style="display:none;" />
                    </label>
                    
                    @if (CaseState.EvidenceFileNames.Any())
                    {
                        <div class="mt-3">
                            <p class="is-size-7 has-text-weight-bold">Archivos cargados:</p>
                            <ul class="is-size-7">
                                @foreach (var name in CaseState.EvidenceFileNames)
                                {
                                    <li class="has-text-success"><i class="fas fa-file-check mr-2"></i> @name</li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                @* MINIATURA DE LA CAMPAÑA *@
                <div class="newcasestep2__section">
                    <div class="newcasestep2__section-header">
                        <span class="newcasestep2__section-icon"><i class="fas fa-camera-retro"></i></span>
                        <h2 class="newcasestep2__section-title">Miniatura de la Campaña</h2>
                    </div>
                    <div class="newcasestep2__thumbnail-wrapper">
                        <label class="newcasestep2__thumbnail-box">
                            <div class="newcasestep2__upload-placeholder">
                                @if (CaseState.ThumbnailData != null)
                                {
                                    <div class="has-text-success mb-2">
                                        <i class="fas fa-image fa-3x"></i>
                                    </div>
                                    <p class="is-size-7">@CaseState.ThumbnailName</p>
                                }
                                else
                                {
                                    <div class="newcasestep2__camera-icon">
                                        <i class="fas fa-camera"></i>
                                        <span class="newcasestep2__plus"><i class="fas fa-plus-circle"></i></span>
                                    </div>
                                    <p class="newcasestep2__upload-text">Cargar Imagen de Portada</p>
                                }
                            </div>
                            @* Added style inline to avoid blocking other elements *@
                            <InputFile OnChange="HandleThumbnailFile" class="newcasestep2__thumbnail-input" accept="image/*" style="position: absolute; opacity: 0; width: 0.1px; height: 0.1px; z-index: -1;" />
                        </label>
                        
                        <div class="newcasestep2__thumbnail-info">
                            <p>La miniatura es lo primero que ven los donantes. Elige una imagen atractiva que represente tu caso con claridad.</p>
                            <ul class="newcasestep2__thumbnail-list">
                                <li><i class="fas fa-check-circle has-text-success mr-2"></i> Alta resolución (mín. 720p)</li>
                                <li><i class="fas fa-check-circle has-text-success mr-2"></i> Respeta la privacidad y la dignidad</li>
                                <li><i class="fas fa-check-circle has-text-success mr-2"></i> Sin contenido violento o gráfico</li>
                            </ul>
                            <p class="newcasestep2__recommended">Tamaño recomendado: 1280×720px (16:9)</p>
                            @if (CaseState.ThumbnailData == null || !string.IsNullOrEmpty(thumbnailError))
                            {
                                <p class="bulma-help bulma-is-danger">@(thumbnailError ?? "Una imagen de portada es requerida.")</p>
                            }
                            @if (!string.IsNullOrEmpty(thumbnailUploadError))
                            {
                                <p class="bulma-help bulma-is-danger">@thumbnailUploadError</p>
                            }
                        </div>
                    </div>
                </div>

                @* MÉTODO DE DESEMBOLSO *@
                <div class="newcasestep2__section">
                    <div class="newcasestep2__section-header">
                        <span class="newcasestep2__section-icon"><i class="fas fa-hand-holding-dollar"></i></span>
                        <h2 class="newcasestep2__section-title">Método de Desembolso</h2>
                    </div>
                    <p class="newcasestep2__section-description">
                        Selecciona cómo te gustaría recibir los fondos una vez que la campaña alcance su objetivo.
                    </p>

                    <div class="newcasestep2__methods-grid">
                        @* Transferencia Bancaria *@
                        <button type="button"
                                class="newcasestep2__method-card @(CaseState.SelectedMethod == "bank" ? "newcasestep2__method-card--selected" : "")"
                                @onclick='() => SelectMethod("bank")'>
                            <div class="newcasestep2__method-icon"><i class="fas fa-building-columns"></i></div>
                            <div class="newcasestep2__method-content">
                                <h3 class="newcasestep2__method-title">Transferencia Bancaria</h3>
                                <span class="newcasestep2__method-badge">RECOMENDADO</span>
                            </div>
                            @if (CaseState.SelectedMethod == "bank")
                            {
                                <span class="newcasestep2__check-icon"><i class="fas fa-circle-check"></i></span>
                            }
                        </button>

                        @* Billetera Digital *@
                        <button type="button"
                                class="newcasestep2__method-card @(CaseState.SelectedMethod == "wallet" ? "newcasestep2__method-card--selected" : "")"
                                @onclick='() => SelectMethod("wallet")'>
                            <div class="newcasestep2__method-icon"><i class="fas fa-credit-card"></i></div>
                            <div class="newcasestep2__method-content">
                                <h3 class="newcasestep2__method-title">Billetera Digital</h3>
                                <span class="newcasestep2__method-badge">PAGO RÁPIDO</span>
                            </div>
                            @if (CaseState.SelectedMethod == "wallet")
                            {
                                <span class="newcasestep2__check-icon"><i class="fas fa-circle-check"></i></span>
                            }
                        </button>

                    </div>

                    @* Formulario de Transferencia Bancaria *@
                    @if (CaseState.SelectedMethod == "bank")
                    {
                        <div class="newcasestep2__bank-form">
                            <div class="bulma-field">
                                <label class="bulma-label">NOMBRE DEL TITULAR DE LA CUENTA</label>
                                <div class="bulma-control">
                                    <InputText class="bulma-input newcasestep2__input" @bind-Value="CaseState.AccountHolder" placeholder="Ingrese el nombre del titular" />
                                </div>
                                <ValidationMessage For="@(() => CaseState.AccountHolder)" class="bulma-help bulma-is-danger" />
                            </div>
                            <div class="bulma-field">
                                <label class="bulma-label">NÚMERO DE CUENTA / IBAN</label>
                                <div class="bulma-control">
                                    <InputText class="bulma-input newcasestep2__input" @bind-Value="CaseState.AccountNumber" placeholder="Ingrese el número de cuenta" />
                                </div>
                                <ValidationMessage For="@(() => CaseState.AccountNumber)" class="bulma-help bulma-is-danger" />
                            </div>
                            <div class="bulma-field">
                                <label class="bulma-label">NOMBRE DEL BANCO</label>
                                <div class="bulma-control">
                                    <InputText class="bulma-input newcasestep2__input" @bind-Value="CaseState.BankName" placeholder="Ingrese el nombre del banco" />
                                </div>
                                <ValidationMessage For="@(() => CaseState.BankName)" class="bulma-help bulma-is-danger" />
                            </div>
                            @if (!string.IsNullOrEmpty(bankValidationError))
                            {
                                <p class="bulma-help bulma-is-danger">@bankValidationError</p>
                            }
                        </div>
                    }

                    @* Formulario de Billetera Digital *@
                    @if (CaseState.SelectedMethod == "wallet")
                    {
                        <div class="newcasestep2__bank-form">
                             <div class="bulma-field">
                                <label class="bulma-label">NÚMERO DE TELÉFONO O CORREO ASOCIADO</label>
                                <div class="bulma-control">
                                    <InputText class="bulma-input newcasestep2__input" @bind-Value="CaseState.AccountNumber" placeholder="Ingrese el número o correo" />
                                </div>
                                <ValidationMessage For="@(() => CaseState.AccountNumber)" class="bulma-help bulma-is-danger" />
                            </div>
                            <div class="bulma-field">
                                <label class="bulma-label">TIPO DE BILLETERA (Chivo, MoMo, etc.)</label>
                                <div class="bulma-control">
                                    <InputText class="bulma-input newcasestep2__input" @bind-Value="CaseState.BankName" placeholder="Ingrese el tipo de billetera" />
                                </div>
                                <ValidationMessage For="@(() => CaseState.BankName)" class="bulma-help bulma-is-danger" />
                            </div>
                        </div>
                    }
                </div>

                @* CASILLA DE CERTIFICACIÓN *@
                <div class="newcasestep2__certification">
                    <label class="newcasestep2__checkbox-container">
                        <InputCheckbox class="newcasestep2__checkbox" @bind-Value="CaseState.IsCertified" />
                        <span class="newcasestep2__checkbox-text">
                            Certifico que la información proporcionada es exacta y veraz. Entiendo que la falsificación de los hechos puede dar lugar 
                            a la cancelación de la campaña y a acciones legales. Acepto los 
                            <a class="newcasestep2__link">Términos de Servicio</a> y la 
                            <a class="newcasestep2__link">Política de Privacidad</a>.
                        </span>
                    </label>
                    <ValidationMessage For="@(() => CaseState.IsCertified)" class="bulma-help bulma-is-danger" />
                    @if (!string.IsNullOrEmpty(certificationError))
                    {
                        <p class="bulma-help bulma-is-danger">@certificationError</p>
                    }
                </div>
            </div>

            @* BOTONES DEL PIE DE PÁGINA *@
            <div class="newcasestep2__footer">
                <button type="button" class="bulma-button bulma-is-light newcasestep2__back-btn" @onclick="OnBackClicked">
                    <i class="fas fa-arrow-left mr-2"></i> Volver a Detalles de la Campaña
                </button>
                <button type="submit" class="bulma-button bulma-is-warning newcasestep2__submit-btn" disabled="@isSubmitting">
                    Enviar para Revisión <i class="fas fa-paper-plane ml-2"></i>
                </button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private string? thumbnailUploadError;
    private long maxFileSize = 15 * 1024 * 1024; // 15MB
    private bool isSubmitting;
    private string? submissionError;
    private readonly List<string> validationMessages = new();

    protected override async Task OnInitializedAsync()
    {
        if (!CaseState.Step1Completed)
        {
            Navigation.NavigateTo("/cases/new/step1");
            return;
        }

        var userId = await GetAuthenticatedUserIdAsync();
        if (userId is null)
        {
            submissionError = "Tu sesión no está activa. Inicia sesión nuevamente para crear un caso.";
            Navigation.NavigateTo("/");
            return;
        }

        if (await CasoService.UsuarioYaTieneCasoAsync(userId.Value))
        {
            Navigation.NavigateTo("/?caseWarning=duplicate");
            return;
        }
    }

    private void SelectMethod(string method)
    {
        bankValidationError = null;
        submissionError = null;
        CaseState.SelectedMethod = method;
        StateHasChanged();
    }

    private async Task HandleEvidenceFiles(InputFileChangeEventArgs e)
    {
        submissionError = null;
        validationMessages.Clear();
        try 
        {
            foreach (var file in e.GetMultipleFiles())
            {
                var buffer = await ReadFileAsync(file);
                CaseState.EvidenceFiles.Add(buffer);
                CaseState.EvidenceFileNames.Add(file.Name);
            }
        }
        catch (Exception ex)
        {
            submissionError = $"No se pudo cargar la evidencia: {GetDisplayError(ex)}";
            await JSRuntime.InvokeVoidAsync("console.error", "Error uploading evidence files:", ex.Message);
        }
    }

    private async Task HandleThumbnailFile(InputFileChangeEventArgs e)
    {
        thumbnailUploadError = null;
        thumbnailError = null;
        submissionError = null;
        validationMessages.Clear();
        try 
        {
            var file = e.File;
            await JSRuntime.InvokeVoidAsync("console.log", $"Handling thumbnail: {file.Name}, Size: {file.Size}");
            
            var buffer = await ReadFileAsync(file);
            CaseState.ThumbnailData = buffer;
            CaseState.ThumbnailName = file.Name;
            
            await JSRuntime.InvokeVoidAsync("console.log", "Thumbnail loaded successfully");
        }
        catch (Exception ex)
        {
            thumbnailUploadError = $"Error al cargar la imagen: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("console.error", "Error uploading thumbnail:", ex.Message);
        }
    }

    private void OnBackClicked()
    {
        Navigation.NavigateTo("/cases/new/step1");
    }

    private string? bankValidationError;
    private string? certificationError;
    private string? thumbnailError;

    private async Task OnInvalidSubmit(EditContext editContext)
    {
        validationMessages.Clear();
        validationMessages.AddRange(editContext.GetValidationMessages().Distinct());
        submissionError = "El formulario tiene campos incompletos o inválidos.";
        await JSRuntime.InvokeVoidAsync("console.error", "Form validation failed");
        Console.WriteLine("Form validation failed");
        foreach (var message in editContext.GetValidationMessages())
        {
            await JSRuntime.InvokeVoidAsync("console.error", "Validation error: " + message);
            Console.WriteLine("Validation error: " + message);
        }
    }

    private async Task OnSubmitClicked()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        await JSRuntime.InvokeVoidAsync("console.log", "OnSubmitClicked started");
        Console.WriteLine("OnSubmitClicked started");

        bankValidationError = null;
        certificationError = null;
        thumbnailError = null;
        thumbnailUploadError = null;
        submissionError = null;
        validationMessages.Clear();

        try
        {
            if (CaseState.SelectedMethod == "bank")
            {
                if (string.IsNullOrWhiteSpace(CaseState.AccountHolder) ||
                    string.IsNullOrWhiteSpace(CaseState.AccountNumber) ||
                    string.IsNullOrWhiteSpace(CaseState.BankName))
                {
                    bankValidationError = "Por favor, complete todos los datos bancarios.";
                    await JSRuntime.InvokeVoidAsync("console.error", "Bank validation error");
                    return;
                }
            }
            else if (CaseState.SelectedMethod == "wallet")
            {
                if (string.IsNullOrWhiteSpace(CaseState.AccountNumber) ||
                    string.IsNullOrWhiteSpace(CaseState.BankName))
                {
                    bankValidationError = "Por favor, complete los datos de su billetera digital.";
                    await JSRuntime.InvokeVoidAsync("console.error", "Wallet validation error");
                    return;
                }
            }

            if (!CaseState.IsCertified)
            {
                certificationError = "Debes certificar que la información es exacta y veraz.";
                await JSRuntime.InvokeVoidAsync("console.error", "Certification error");
                return;
            }

            if (CaseState.ThumbnailData == null)
            {
                thumbnailError = "Una imagen de portada es requerida.";
                await JSRuntime.InvokeVoidAsync("console.error", "Thumbnail error");
                return;
            }

            var userId = await GetAuthenticatedUserIdAsync();
            if (userId is null)
            {
                submissionError = "Tu sesión no está activa. Inicia sesión nuevamente para enviar el caso.";
                return;
            }

            if (await CasoService.UsuarioYaTieneCasoAsync(userId.Value))
            {
                Navigation.NavigateTo("/?caseWarning=duplicate");
                return;
            }

            await JSRuntime.InvokeVoidAsync("console.log", $"User ID: {userId.Value}");

            var thumbnailPath = string.Empty;
            if (CaseState.ThumbnailData != null)
            {
                var fileName = $"case_{Guid.NewGuid()}_{Path.GetFileName(CaseState.ThumbnailName)}";
                var uploadPath = Path.Combine(Environment.WebRootPath, "uploads", "casos");
                if (!Directory.Exists(uploadPath))
                {
                    Directory.CreateDirectory(uploadPath);
                }

                var fullPath = Path.Combine(uploadPath, fileName);
                await File.WriteAllBytesAsync(fullPath, CaseState.ThumbnailData);
                thumbnailPath = $"uploads/casos/{fileName}";
                await JSRuntime.InvokeVoidAsync("console.log", $"Thumbnail saved to {thumbnailPath}");
            }

            if (CaseState.EvidenceFiles.Any())
            {
                var evidencePath = Path.Combine(Environment.WebRootPath, "uploads", "casos", "evidencias");
                if (!Directory.Exists(evidencePath))
                {
                    Directory.CreateDirectory(evidencePath);
                }

                for (int i = 0; i < CaseState.EvidenceFiles.Count; i++)
                {
                    var originalFileName = CaseState.EvidenceFileNames.Count > i
                        ? CaseState.EvidenceFileNames[i]
                        : $"evidencia_{i + 1}";
                    var fileName = $"case_evidence_{Guid.NewGuid()}_{Path.GetFileName(originalFileName)}";
                    var fullPath = Path.Combine(evidencePath, fileName);
                    await File.WriteAllBytesAsync(fullPath, CaseState.EvidenceFiles[i]);
                }

                await JSRuntime.InvokeVoidAsync("console.log", $"{CaseState.EvidenceFiles.Count} evidence files saved.");
            }

            var nuevoCaso = new Caso
            {
                IdBeneficiado = userId.Value,
                Titulo = CaseState.CaseTitle,
                Descripcion = CaseState.Description,
                Meta = CaseState.FinancialGoal,
                IdCategoria = CaseState.CategoryId ?? 0,
                ImagenUrl = thumbnailPath,
                Estado = "Pendiente",
                FechaCreacion = DateTime.Now
            };

            await JSRuntime.InvokeVoidAsync("console.log", "Saving case to database...", nuevoCaso);
            await CasoService.Crear(nuevoCaso);
            await JSRuntime.InvokeVoidAsync("console.log", "Case saved successfully");

            CaseState.Reset();
            await JSRuntime.InvokeVoidAsync("console.log", "State reset, redirecting to home");
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            submissionError = $"No se pudo enviar el caso para revisión: {GetDisplayError(ex)}";
            await JSRuntime.InvokeVoidAsync("console.error", "Error during case submission:", ex.Message);
            Console.WriteLine($"Error during case submission: {ex}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<byte[]> ReadFileAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        return memoryStream.ToArray();
    }

    private static string GetDisplayError(Exception ex)
    {
        var baseException = ex.GetBaseException();
        return string.IsNullOrWhiteSpace(baseException.Message)
            ? "Ocurrió un error inesperado."
            : baseException.Message;
    }

    private async Task<int?> GetAuthenticatedUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity == null || !user.Identity.IsAuthenticated)
        {
            await JSRuntime.InvokeVoidAsync("console.error", "User not authenticated");
            Console.WriteLine("User not authenticated");
            return null;
        }

        var userIdString = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userIdString) || !int.TryParse(userIdString, out var userId))
        {
            await JSRuntime.InvokeVoidAsync("console.error", "Could not retrieve user ID", userIdString);
            Console.WriteLine($"Could not retrieve user ID: {userIdString}");
            return null;
        }

        return userId;
    }
}
