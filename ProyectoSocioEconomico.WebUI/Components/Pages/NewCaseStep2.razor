@* NewCaseStep2.razor *@
@page "/cases/new/step2"
@using ProyectoSocioEconomico.WebUI.Services
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@inject NewCaseState CaseState
@inject ICasoService CasoService
@inject NavigationManager Navigation

<div class="newcasestep2-page">
    <div class="newcasestep2__container">
        
        @* PROGRESS BAR – idéntico al estilo de tu register-page pero con amarillo *@
        <div class="newcasestep2__progress-section">
            <div class="newcasestep2__progress-header">
                <span class="newcasestep2__step">Step 2 of 2</span>
                <span class="newcasestep2__step-label">100% COMPLETED</span>
            </div>
            <progress class="bulma-progress newcasestep2__progress-bar" value="100" max="100"></progress>
        </div>

        @* HEADING *@
        <div class="newcasestep2__heading-block">
            <h1 class="newcasestep2__title">Finalize Campaign</h1>
            <p class="newcasestep2__subtitle">Verification and disbursement details</p>
        </div>

        <div class="newcasestep2__content">

            @* SUPPORTING EVIDENCE *@
            <div class="newcasestep2__section">
                <div class="newcasestep2__section-header">
                    <span class="newcasestep2__section-icon">🛡️</span>
                    <h2 class="newcasestep2__section-title">Supporting Evidence</h2>
                </div>
                <p class="newcasestep2__section-description">
                    To ensure transparency and build trust with donors, please upload official documents such as medical bills, 
                    prescriptions, or utility statements. Accepted formats: PDF, JPG, PNG. Max 5MB per file.
                </p>

                @* Drag & Drop / Select Files *@
                <label class="newcasestep2__upload-area">
                    <InputFile OnChange="HandleEvidenceFiles" class="newcasestep2__file-input" multiple />
                    <div class="newcasestep2__dropzone">
                        <div class="newcasestep2__cloud-icon">☁️</div>
                        <p class="newcasestep2__drop-text">Drag and drop files here</p>
                        <p class="newcasestep2__drop-text">or click to browse from your computer</p>
                        <button type="button" class="bulma-button bulma-is-dark newcasestep2__select-btn">
                            Select Files
                        </button>
                    </div>
                </label>
                
                @if (CaseState.EvidenceFileNames.Any())
                {
                    <div class="mt-3">
                        <p class="is-size-7 has-text-weight-bold">Uploaded files:</p>
                        <ul class="is-size-7">
                            @foreach (var name in CaseState.EvidenceFileNames)
                            {
                                <li>@name</li>
                            }
                        </ul>
                    </div>
                }
            </div>

            @* CAMPAIGN THUMBNAIL *@
            <div class="newcasestep2__section">
                <div class="newcasestep2__section-header">
                    <span class="newcasestep2__section-icon">📸</span>
                    <h2 class="newcasestep2__section-title">Campaign Thumbnail</h2>
                </div>
                <div class="newcasestep2__thumbnail-wrapper">
                    <label class="newcasestep2__thumbnail-box">
                        <InputFile OnChange="HandleThumbnailFile" class="newcasestep2__file-input" accept="image/*" />
                        <div class="newcasestep2__upload-placeholder">
                            @if (CaseState.ThumbnailData != null)
                            {
                                <p class="is-size-7">@CaseState.ThumbnailName</p>
                            }
                            else
                            {
                                <div class="newcasestep2__camera-icon">📷<span class="newcasestep2__plus">+</span></div>
                                <p class="newcasestep2__upload-text">Upload Cover Image</p>
                            }
                        </div>
                    </label>
                    
                    <div class="newcasestep2__thumbnail-info">
                        <p>The thumbnail is the first thing donors see. Choose a compelling image that represents your case clearly.</p>
                        <ul class="newcasestep2__thumbnail-list">
                            <li>✔ High resolution (min 720p)</li>
                            <li>✔ Respects privacy and dignity</li>
                            <li>✔ No violent or graphic content</li>
                        </ul>
                        <p class="newcasestep2__recommended">Recommended size: 1280×720px (16:9)</p>
                    </div>
                </div>
            </div>

            @* DISBURSEMENT METHOD *@
            <div class="newcasestep2__section">
                <div class="newcasestep2__section-header">
                    <span class="newcasestep2__section-icon">💰</span>
                    <h2 class="newcasestep2__section-title">Disbursement Method</h2>
                </div>
                <p class="newcasestep2__section-description">
                    Select how you would like to receive the funds once the campaign reaches its goal.
                </p>

                <div class="newcasestep2__methods-grid">
                    @* Bank Transfer (seleccionado por defecto) *@
                    <div class="newcasestep2__method-card @(CaseState.SelectedMethod == "bank" ? "newcasestep2__method-card--selected" : "")"
                         @onclick='() => SelectMethod("bank")'>
                        <div class="newcasestep2__method-icon">🏦</div>
                        <div class="newcasestep2__method-content">
                            <h3 class="newcasestep2__method-title">Bank Transfer</h3>
                            <span class="newcasestep2__method-badge">RECOMMENDED</span>
                        </div>
                        @if (CaseState.SelectedMethod == "bank")
                        {
                            <span class="newcasestep2__check-icon">✔</span>
                        }
                    </div>

                    @* Digital Wallet *@
                    <div class="newcasestep2__method-card @(CaseState.SelectedMethod == "wallet" ? "newcasestep2__method-card--selected" : "")"
                         @onclick='() => SelectMethod("wallet")'>
                        <div class="newcasestep2__method-icon">💳</div>
                        <div class="newcasestep2__method-content">
                            <h3 class="newcasestep2__method-title">Digital Wallet</h3>
                            <span class="newcasestep2__method-badge">FAST PAYOUT</span>
                        </div>
                    </div>

                    @* Direct Utility Pay *@
                    <div class="newcasestep2__method-card @(CaseState.SelectedMethod == "utility" ? "newcasestep2__method-card--selected" : "")"
                         @onclick='() => SelectMethod("utility")'>
                        <div class="newcasestep2__method-icon">📧</div>
                        <div class="newcasestep2__method-content">
                            <h3 class="newcasestep2__method-title">Direct Utility Pay</h3>
                            <span class="newcasestep2__method-badge">PAY BILLS DIRECTLY</span>
                        </div>
                    </div>
                </div>

                @* Formulario solo visible cuando se elige Bank Transfer (como en la imagen) *@
                @if (CaseState.SelectedMethod == "bank")
                {
                    <div class="newcasestep2__bank-form">
                        <div class="bulma-field">
                            <label class="bulma-label">ACCOUNT HOLDER NAME</label>
                            <div class="bulma-control">
                                <input type="text" class="bulma-input newcasestep2__input" @bind="CaseState.AccountHolder" />
                            </div>
                        </div>
                        <div class="bulma-field">
                            <label class="bulma-label">ACCOUNT NUMBER / IBAN</label>
                            <div class="bulma-control">
                                <input type="text" class="bulma-input newcasestep2__input" @bind="CaseState.AccountNumber" />
                            </div>
                        </div>
                        <div class="bulma-field">
                            <label class="bulma-label">BANK NAME</label>
                            <div class="bulma-control">
                                <input type="text" class="bulma-input newcasestep2__input" @bind="CaseState.BankName" />
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* CERTIFICATION CHECKBOX *@
            <div class="newcasestep2__certification">
                <label class="newcasestep2__checkbox-container">
                    <input type="checkbox" class="newcasestep2__checkbox" @bind="CaseState.IsCertified" />
                    <span class="newcasestep2__checkbox-text">
                        I certify that the information provided is accurate and truthful. I understand that misrepresentation of facts may lead 
                        to campaign cancellation and legal action. I agree to the 
                        <a href="#" class="newcasestep2__link">Terms of Service</a> and 
                        <a href="#" class="newcasestep2__link">Privacy Policy</a>.
                    </span>
                </label>
            </div>
        </div>

        @* FOOTER BUTTONS *@
        <div class="newcasestep2__footer">
            <button type="button" class="bulma-button bulma-is-light newcasestep2__back-btn" @onclick="OnBackClicked">
                ← Back to Campaign Details
            </button>
            <button type="button" class="bulma-button bulma-is-warning newcasestep2__submit-btn" @onclick="OnSubmitClicked">
                Submit for Review →
            </button>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!CaseState.Step1Completed)
        {
            Navigation.NavigateTo("/cases/new/step1");
        }
    }

    private void SelectMethod(string method)
    {
        CaseState.SelectedMethod = method;
    }

    private async Task HandleEvidenceFiles(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
            CaseState.EvidenceFiles.Add(buffer);
            CaseState.EvidenceFileNames.Add(file.Name);
        }
    }

    private async Task HandleThumbnailFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
        CaseState.ThumbnailData = buffer;
        CaseState.ThumbnailName = file.Name;
    }

    private void OnBackClicked()
    {
        Navigation.NavigateTo("/cases/new/step1");
    }

    private async Task OnSubmitClicked()
    {
        if (!CaseState.IsCertified)
        {
            // Podrías usar un JS alert o un componente de notificación
            return;
        }

        // Aquí iría la lógica de guardado final
        // await CasoService.Crear(nuevoCaso);
        
        CaseState.Reset();
        Navigation.NavigateTo("/cases"); // O a una página de éxito
    }
}
