@page "/registrarse/step3"
@using System.Text.RegularExpressions
@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Infrastructure.Data
@layout EmptyLayout
@inject NavigationManager Navigation
@inject ProyectoSocioEconomico.WebUI.Services.RegistrationState RegState
@inject AppDbContext DbContext
@inject IWebHostEnvironment Environment
@inject ProyectoSocioEconomico.WebUI.Services.CustomAuthenticationStateProvider AuthStateProvider
@using ProyectoSocioEconomico.Application.Interfaces
@inject IUsuarioService UsuarioService

<div class="rp3-page">
    <!-- ── MAIN ── -->
    <main class="rp3-main">
        <div class="rp3-card">

            <!-- ── PROGRESS ── -->
            <div class="rp3-progress-section">
                <div class="rp3-progress-section__header">
                    <span class="rp3-progress-section__eyebrow">PROCESO DE REGISTRO</span>
                    <span class="rp3-progress-section__step-count">Paso 3 de 3</span>
                </div>
                <progress class="bulma-progress bulma-is-success rp3-progress-bar" value="100" max="100">100%</progress>
                <div class="rp3-progress-section__steps">
                    <span class="rp3-progress-section__step-name">Info Personal</span>
                    <span class="rp3-progress-section__step-name">Verificación</span>
                    <span class="rp3-progress-section__step-name rp3-progress-section__step-name--active">Seguridad y Rol</span>
                </div>
            </div>

            <!-- ── HEADING ── -->
            <div class="rp3-heading">
                <h1 class="rp3-heading__title">Seguridad y Configuración</h1>
                <p class="rp3-heading__subtitle">Finaliza tus credencialess.</p>
            </div>

            <!-- ── FORM ── -->
            <div class="rp3-form">

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="bulma-notification bulma-is-danger bulma-is-light bulma-py-2 bulma-px-3 bulma-mb-4" style="font-size: 0.9rem;">
                        <i class="fa-solid fa-circle-exclamation bulma-mr-2"></i> @mensajeError
                    </div>
                }

                <!-- Email -->
                <div class="bulma-field rp3-field">
                    <label class="bulma-label rp3-label" for="email">Correo Electrónico</label>
                    <div class="bulma-control bulma-has-icons-right rp3-control">
                        <input id="email" class="bulma-input rp3-input @(mostrarErrores && !EsEmailValido(RegState.Email) ? "bulma-is-danger" : "")" 
                               type="email" placeholder="ejemplo@correo.com"
                               @bind="RegState.Email" />
                        <span class="bulma-icon bulma-is-right rp3-input-icon">
                            <i class="far fa-envelope"></i>
                        </span>
                    </div>
                    @if (mostrarErrores && !EsEmailValido(RegState.Email))
                    {
                        <p class="bulma-help bulma-is-danger">Por favor, ingresa un correo electrónico válido.</p>
                    }
                </div>

                <!-- Passwords row -->
                <div class="rp3-passwords-row">

                    <!-- Create Password -->
                    <div class="bulma-field rp3-field rp3-field--half">
                        <label class="bulma-label rp3-label" for="password">Crear Contraseña</label>
                        <div class="bulma-control bulma-has-icons-right rp3-control">
                            <input id="password" class="bulma-input rp3-input @(mostrarErrores && !EsPasswordValido(RegState.Password) ? "bulma-is-danger" : "")"
                                   type="@(ShowPassword ? "text" : "password")" placeholder="••••••••" @bind="RegState.Password"
                                   @oninput="OnPasswordInput" />
                            <span class="bulma-icon bulma-is-right rp3-input-icon rp3-input-icon--clickable"
                                  @onclick="TogglePassword">
                                <i class="@(ShowPassword ? "far fa-eye" : "far fa-eye-slash")"></i>
                            </span>
                        </div>
                        @if (mostrarErrores && !EsPasswordValido(RegState.Password))
                        {
                            <p class="bulma-help bulma-is-danger">Mínimo 8 caracteres.</p>
                        }
                    </div>

                    <!-- Confirm Password -->
                    <div class="bulma-field rp3-field rp3-field--half">
                        <label class="bulma-label rp3-label" for="confirm-password">Confirmar Contraseña</label>
                        <div class="bulma-control bulma-has-icons-right rp3-control">
                            <input id="confirm-password" class="bulma-input rp3-input @(mostrarErrores && RegState.Password != ConfirmPassword ? "bulma-is-danger" : "")"
                                   type="@(ShowConfirm ? "text" : "password")" placeholder="••••••••"
                                   @bind="ConfirmPassword" />
                            <span class="bulma-icon bulma-is-right rp3-input-icon rp3-input-icon--clickable"
                                  @onclick="ToggleConfirm">
                                <i class="@(ShowConfirm ? "far fa-eye" : "far fa-eye-slash")"></i>
                            </span>
                        </div>
                        @if (mostrarErrores && RegState.Password != ConfirmPassword)
                        {
                            <p class="bulma-help bulma-is-danger">Las contraseñas no coinciden.</p>
                        }
                    </div>
                </div>
                <!-- Terms -->
                <div class="bulma-field rp3-field rp3-field--terms">
                    <label class="bulma-checkbox rp3-checkbox">
                        <input type="checkbox" class="rp3-checkbox__input" @bind="AgreeTerms" />
                        <span class="rp3-checkbox__box"></span>
                        <span class="rp3-checkbox__text">
                            Acepto los
                            <span class="rp3-link">Términos de Servicio</span>
                            y la
                            <span href="/privacy" class="rp3-link">Política de Privacidad</span>.
                            Entiendo que mis datos serán utilizados para el análisis socioeconómico.
                        </span>
                    </label>
                </div>

                <!-- Submit -->
                <button type="button" class="bulma-button bulma-is-warning bulma-is-fullwidth rp3-btn-create"
                        disabled="@(!AgreeTerms)" @onclick="HandleSubmit">
                    <strong>Crear Cuenta</strong>
                </button>

            </div><!-- /rp3-form -->
        </div><!-- /rp3-card -->
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        if (!RegState.Step2Completed)
        {
            Navigation.NavigateTo("/");
        }
    }

    private string ConfirmPassword { get; set; } = string.Empty;
    private bool ShowPassword { get; set; } = false;
    private bool ShowConfirm { get; set; } = false;
    private bool AgreeTerms { get; set; } = false;
    private int StrengthScore { get; set; } = 0;
    private string mensajeError = string.Empty;
    private bool mostrarErrores = false;

    private string StrengthLabel => StrengthScore switch
    {
        1 => "DÉBIL",
        2 => "REGULAR",
        3 => "BUENA",
        4 => "FUERTE",
        _ => ""
    };

    private void TogglePassword() => ShowPassword = !ShowPassword;
    private void ToggleConfirm() => ShowConfirm = !ShowConfirm;

    private void OnPasswordInput(ChangeEventArgs e)
    {
        RegState.Password = e.Value?.ToString() ?? string.Empty;
        StrengthScore = ComputeStrength(RegState.Password);
    }

    private int ComputeStrength(string pwd)
    {
        if (string.IsNullOrEmpty(pwd)) return 0;
        int score = 0;
        if (pwd.Length >= 8) score++;
        if (Regex.IsMatch(pwd, @"[A-Z]")) score++;
        if (Regex.IsMatch(pwd, @"[0-9]")) score++;
        if (Regex.IsMatch(pwd, @"[^a-zA-Z0-9]")) score++;
        return score;
    }

    private bool EsEmailValido(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        return Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
    }

    private bool EsPasswordValido(string pwd)
    {
        return !string.IsNullOrWhiteSpace(pwd) && pwd.Length >= 8;
    }

    private string GetBarClass(int bar)
    {
        if (StrengthScore == 0) return string.Empty;
        return bar <= StrengthScore ? "rp3-strength__bar--filled" : string.Empty;
    }

    private async Task HandleSubmit()
    {
        mensajeError = string.Empty;
        mostrarErrores = true;

        if (!EsEmailValido(RegState.Email))
        {
            mensajeError = "Por favor, ingresa un correo electrónico válido.";
            return;
        }

        if (!EsPasswordValido(RegState.Password))
        {
            mensajeError = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        if (RegState.Password != ConfirmPassword)
        {
            mensajeError = "Las contraseñas no coinciden.";
            return;
        }

        if (!AgreeTerms)
        {
            mensajeError = "Debes aceptar los términos y condiciones.";
            return;
        }

        try
        {
            // 1. Verificar si el email ya existe
            if (await DbContext.Usuarios.AnyAsync(u => u.Email == RegState.Email))
            {
                mensajeError = "El correo electrónico ya está registrado.";
                return;
            }

            // 2. Obtener Rol "Donador"
            var rolDonador = await DbContext.Roles.FirstOrDefaultAsync(r => r.Nombre.ToLower() == "donador");
            if (rolDonador == null)
            {
                rolDonador = new Role 
                { 
                    Nombre = "Donador", 
                    Descripcion = "Usuario que realiza donaciones", 
                    Estado = "Activo" 
                };
                DbContext.Roles.Add(rolDonador);
                await DbContext.SaveChangesAsync();
            }

            // 3. Guardar Archivos DUI
            string frontPath = await SaveFileData(RegState.DuiFrontData, RegState.DuiFrontName, "front");
            string backPath = await SaveFileData(RegState.DuiBackData, RegState.DuiBackName, "back");

            // 4. Crear Usuario
            var nuevoUsuario = new Usuario
            {
                Nombre = RegState.FirstName,
                Apellido = RegState.LastName,
                Email = RegState.Email,
                PasswordHash = UsuarioService.HashPassword(RegState.Password), 
                FechaNacimiento = RegState.BirthDate ?? DateTime.Now,
                Dui = RegState.DuiNumber,
                Telefono = RegState.PhoneNumber,
                IdRol = rolDonador.Id,
                Estado = "Activo",
                FechaRegistro = DateTime.Now,
                ImagenPerfil = "uploads/profiles/DefaultProfile.png",
                FrontDUI = frontPath,
                ReverseDUI = backPath
            };

            DbContext.Usuarios.Add(nuevoUsuario);
            await DbContext.SaveChangesAsync();

            // 5. Iniciar sesión automáticamente
            await AuthStateProvider.NotifyUserLogin(nuevoUsuario);

            // 6. Finalizar
            RegState.Reset();
            Navigation.NavigateTo("/"); 
        }
        catch (Exception ex)
        {
            mensajeError = "Error al registrar: " + ex.Message;
        }
    }

    private async Task<string> SaveFileData(byte[]? data, string? originalName, string prefix)
    {
        if (data == null || string.IsNullOrEmpty(originalName)) return string.Empty;

        var fileName = $"{prefix}_{Guid.NewGuid()}{Path.GetExtension(originalName)}";
        var relativePath = Path.Combine("uploads", "documents", "dui", fileName);
        var physicalPath = Path.Combine(Environment.WebRootPath, relativePath);

        // Asegurar que el directorio existe
        var directory = Path.GetDirectoryName(physicalPath);
        if (!Directory.Exists(directory)) Directory.CreateDirectory(directory!);

        await File.WriteAllBytesAsync(physicalPath, data);

        return relativePath.Replace("\\", "/");
    }
}
