@page "/registrarse"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="register-page">
    <!-- MAIN CONTENT -->
    <main class="register-page__main">
        <div class="register-page__card">

            <!-- PROGRESS -->
            <div class="register-page__progress-section">
                <div class="register-page__progress-header">
                    <span class="register-page__step-label">Paso 1 de 3</span>
                </div>
                <progress class="register-page__progress-bar bulma-progress bulma-is-success" value="33"
                          max="100">33%</progress>
            </div>

            <!-- HEADING -->
            <div class="register-page__heading-block">
                <h1 class="register-page__title">¡Bienvenido! Comencemos</h1>
                <p class="register-page__subtitle">
                    Ayúdanos a identificarte para brindarte un mejor<br />
                    análisis socioeconómico y gestión de ayuda social.
                </p>
            </div>

            <!-- FORM FIELDS -->
            <div class="register-page__form">

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="bulma-notification bulma-is-danger bulma-is-light bulma-py-2 bulma-px-3 bulma-mb-4" style="font-size: 0.9rem;">
                        <i class="fa-solid fa-circle-exclamation bulma-mr-2"></i> @mensajeError
                    </div>
                }

                <!-- Full Name -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Nombre Completo</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <input class="register-page__input bulma-input @(mostrarErrores && (string.IsNullOrWhiteSpace(fullName) || fullName.Trim().Length < 3) ? "bulma-is-danger" : "")" 
                               type="text"
                               placeholder="Ingresa tu nombre completo" 
                               @bind="fullName" />
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </span>
                    </div>
                </div>

                <!-- Country of Residence -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">País de Residencia</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <div class="register-page__select-wrapper bulma-select bulma-is-fullwidth">
                            <select class="register-page__select" @bind="selectedCountry">
                                @foreach (var country in countryPrefixes.Keys)
                                {
                                    <option value="@country">@country</option>
                                }
                            </select>
                        </div>
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="2" y1="12" x2="22" y2="12" />
                                <path
                                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <!-- Phone Number -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Número de Teléfono</label>
                    <div class="register-page__phone-group">
                        <div class="register-page__phone-prefix">
                            <span class="register-page__phone-icon">
                                <i class="fa-solid fa-mobile"></i>
                            </span>
                            <span class="register-page__phone-code">@GetPrefix()</span>
                        </div>
                        <input class="register-page__phone-input bulma-input @(mostrarErrores && !EsTelefonoValido(phoneNumber) ? "bulma-is-danger" : "")" 
                               type="tel" 
                               placeholder="0000-0000" 
                               value="@phoneNumber"
                               @oninput="HandlePhoneInput" />
                    </div>
                </div>
                <!-- Next Step Button -->
                <button class="bulma-button bulma-is-fullwidth bulma-is-warning bulma-has-text-weight-bold" @onclick="GoToStep2">
                    Siguiente Paso
                    <span class="register-page__btn-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </span>
                </button>
            </div>

            <!-- FOOTER HELP -->
            <p class="register-page__help-text">
                ¿Ya tienes una cuenta?
                <a class="register-page__help-link" href="/login">Iniciar sesión</a>
            </p>

        </div>
    </main>
</div>

@code {
    private string fullName = string.Empty;
    private string phoneNumber = string.Empty;
    private string selectedCountry = "El Salvador";
    private string mensajeError = string.Empty;
    private bool mostrarErrores = false;

    private Dictionary<string, string> countryPrefixes = new()
    {
        { "El Salvador", "+503" },
        { "Guatemala", "+502" },
        { "Honduras", "+504" },
        { "México", "+52" },
        { "Estados Unidos", "+1" }
    };

    private string GetPrefix() => countryPrefixes.TryGetValue(selectedCountry, out var prefix) ? prefix : "+503";

    private void HandlePhoneInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        // Solo permitir números (eliminar guiones y otros caracteres)
        phoneNumber = new string(value.Where(char.IsDigit).ToArray());
    }

    private bool EsTelefonoValido(string telefono)
    {
        if (string.IsNullOrWhiteSpace(telefono)) return false;
        // Validar que tenga exactamente 8 dígitos o al menos 8 (según prefieras, dejaré >= 8 por flexibilidad)
        return telefono.Length >= 8;
    }

    private void GoToStep2()
    {
        mensajeError = string.Empty;
        mostrarErrores = true;

        if (string.IsNullOrWhiteSpace(fullName) || fullName.Trim().Length < 3)
        {
            mensajeError = "Por favor, ingresa tu nombre completo (mínimo 3 caracteres).";
            return;
        }

        if (!EsTelefonoValido(phoneNumber))
        {
            mensajeError = "Por favor, ingresa un número de teléfono válido (mínimo 8 dígitos).";
            return;
        }

        Navigation.NavigateTo("/registrarse/step2");
    }
}

