@page "/programs"
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using Microsoft.AspNetCore.Components
@inject IProgramaService ProgramaService

<div class="cap-page">

    <!-- ═══════════════ HEADER ═══════════════ -->
    <div class="cap-header">
        <h1 class="cap-header__title">Community Aid Programs</h1>
        <p class="cap-header__subtitle">
            Discover and track socioeconomic development initiatives. We focus on transparency and
            measurable community impact.
        </p>
    </div>

    <!-- ═══════════════ SEARCH + FILTERS ═══════════════ -->
    <div class="cap-toolbar">
        <div class="bulma-control bulma-has-icons-left cap-toolbar__search-wrap">
            <input class="bulma-input cap-toolbar__search"
                   type="text"
                   placeholder="Search for programs (e.g., 'Well Construction')"
                   @bind="SearchQuery"
                   @oninput="OnSearch" />
            <span class="bulma-icon bulma-is-left cap-toolbar__search-icon">
                <i class="fas fa-magnifying-glass"></i>
            </span>
        </div>

        <div class="cap-toolbar__filters">
            @foreach (var filter in Filters)
            {
                <button class="cap-filter-btn @(ActiveFilter == filter.Key ? "cap-filter-btn--active" : "")"
                        @onclick="() => SetFilter(filter.Key)">
                    <span class="bulma-icon bulma-is-small">
                        <i class="@filter.Icon"></i>
                    </span>
                    @filter.Label
                </button>
            }
        </div>
    </div>

    <!-- ═══════════════ PROGRAM GRID ═══════════════ -->
    <div class="cap-grid">
        @if (PagedPrograms != null)
        {
            @foreach (var program in PagedPrograms)
            {
                <ProgramCardComponent Id="@program.Id"
                                      Title="@program.Nombre"
                                      Description="@program.Descripcion"
                                      Category="@GetCategoryName(program)"
                                      ProgressLabel="Progress"
                                      Progress="@CalculateOverallProgress(program)"
                                      ImageUrl="@program.ImagenUrl" />
            }
        }
    </div>

    <!-- ═══════════════ PAGINATION ═══════════════ -->
    <nav class="cap-pagination" aria-label="pagination">
        <button class="cap-pagination__btn"
                disabled="@(CurrentPage == 1)"
                @onclick="() => GoToPage(CurrentPage - 1)">
            Previous
        </button>

        @for (int p = 1; p <= TotalPages; p++)
        {
            int pageNumber = p;
            <button class="cap-pagination__btn @(CurrentPage == pageNumber ? "cap-pagination__btn--active" : "")"
                    @onclick="() => GoToPage(pageNumber)">
                @pageNumber
            </button>
        }

        <button class="cap-pagination__btn"
                disabled="@(CurrentPage == TotalPages)"
                @onclick="() => GoToPage(CurrentPage + 1)">
            Next
        </button>
    </nav>

</div>

@code {
    private record FilterOption(string Key, string Label, string Icon);

    [SupplyParameterFromQuery(Name = "category")]
    private string? CategoryFromUrl { get; set; }

    private string SearchQuery  { get; set; } = string.Empty;
    private string ActiveFilter { get; set; } = "all";
    private int    CurrentPage  { get; set; } = 1;
    private const int PageSize  = 6;

    private List<FilterOption> Filters = new()
    {
        new("all",            "Todos",          "fas fa-table-cells-large"),
        new("salud",          "Salud",          "fas fa-heart-pulse"),
        new("educacion",      "Educación",      "fas fa-graduation-cap"),
        new("infraestructura","Infraestructura","fas fa-wrench"),
        new("desastres naturales", "Desastres Naturales", "fas fa-house-chimney-crack"),
        new("naturaleza",     "Naturaleza",     "fas fa-leaf"),
    };

    private List<Programa> AllPrograms = new();

    protected override async Task OnInitializedAsync()
    {
        AllPrograms = await ProgramaService.ObtenerTodosConCasosAsync();
    }

    protected override void OnParametersSet()
    {
        var normalizedCategory = CategoryFromUrl?.Trim().ToLowerInvariant();
        ActiveFilter = Filters.Any(filter => filter.Key == normalizedCategory) ? normalizedCategory! : "all";
        CurrentPage = 1;
    }

    private IEnumerable<Programa> FilteredPrograms =>
        AllPrograms
            .Where(p => ActiveFilter == "all" || IsMatch(GetCategoryName(p), ActiveFilter))
            .Where(p => string.IsNullOrWhiteSpace(SearchQuery) ||
                        p.Nombre.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                        p.Descripcion.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    private bool IsMatch(string categoryName, string filterKey)
    {
        var name = categoryName.ToLower();
        if (filterKey == "educacion" && (name.Contains("educacion") || name.Contains("educación"))) return true;
        if (filterKey == "desastres naturales" && (name.Contains("desastres") || name.Contains("emergencia"))) return true;
        return name == filterKey;
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredPrograms.Count() / PageSize));

    private IEnumerable<Programa> PagedPrograms =>
        FilteredPrograms.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private void SetFilter(string key)
    {
        ActiveFilter = key;
        CurrentPage  = 1;
    }

    private void OnSearch(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
            CurrentPage = page;
    }

    private string GetCategoryName(Programa p)
    {
        return p.IdCategoriaNavigation?.Nombre ?? "Otro";
    }

    private int CalculateOverallProgress(Programa p)
    {
        decimal totalMeta = p.MetaFinanciera;
        decimal totalRecaudado = p.IdCasos.SelectMany(c => c.Donaciones).Sum(d => d.Monto);

        if (totalMeta <= 0) return 0;

        return Math.Clamp((int)Math.Round((totalRecaudado / totalMeta) * 100), 0, 100);
    }
}
