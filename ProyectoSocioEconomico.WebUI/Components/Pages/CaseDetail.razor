@page "/cases/{Id:int}"
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using System.Globalization
@inject ICasoService CasoService

@if (Caso == null)
{
    <div class="bulma-container">
        <p>Cargando detalles del caso...</p>
    </div>
}
else
{
    <div class="pd-page">
        <!-- ═══════════════ HERO ═══════════════ -->
        <div class="pd-hero">
            @if (!string.IsNullOrEmpty(Caso.ImagenUrl))
            {
                <img class="pd-hero__image" src="@Caso.ImagenUrl" alt="@Caso.Titulo" />
            }
            else
            {
                <img class="pd-hero__image" src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1200&q=80" alt="Placeholder" />
            }
            <div class="pd-hero__overlay"></div>
            <div class="pd-hero__content">
                <span class="pd-hero__status-badge">CASO @Caso.Estado.ToUpper()</span>
                <h1 class="pd-hero__title">@Caso.Titulo</h1>
            </div>
        </div>

        <!-- ═══════════════ BODY ═══════════════ -->
        <div class="pd-body">

            <!-- ── LEFT / MAIN COLUMN ── -->
            <div class="pd-body__main">

                <!-- Descripción del Caso -->
                <section class="pd-section">
                    <h2 class="pd-section__heading">
                        <span class="pd-section__heading-icon">
                            <i class="fas fa-info-circle"></i>
                        </span>
                        Descripción del Caso
                    </h2>
                    <p class="pd-section__text">@Caso.Descripcion</p>
                </section>

                <!-- Detalles del Beneficiario -->
                <section class="pd-section">
                    <h3 class="pd-section__subheading">Información del Beneficiario</h3>
                    <div class="pd-goal-card" style="max-width: 400px;">
                        <span class="pd-goal-card__icon">
                            <i class="fas fa-user"></i>
                        </span>
                        <p class="pd-goal-card__value">@Caso.IdBeneficiadoNavigation?.Nombre @Caso.IdBeneficiadoNavigation?.Apellido</p>
                        <p class="pd-goal-card__desc">Beneficiario principal del caso.</p>
                    </div>
                </section>

                <!-- Impacto y Progreso -->
                <section class="pd-impact-card">
                    <div class="pd-impact-card__header">
                        <div>
                            <h3 class="pd-impact-card__title">Progreso de Recaudación</h3>
                            <p class="pd-impact-card__subtitle">Seguimiento en tiempo real de la meta financiera</p>
                        </div>
                    </div>

                    <div class="pd-impact-card__metrics">
                        @{
                            decimal totalRecaudado = Caso.Donaciones?.Sum(d => d.Monto) ?? 0m;
                            int progreso = CalcularPorcentaje(Caso.Meta, totalRecaudado);
                        }
                        <div class="pd-metric">
                            <div class="pd-metric__header">
                                <span class="pd-metric__label">Recaudado vs Meta</span>
                                <span class="pd-metric__achievement">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV")) de @Caso.Meta.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                            </div>
                            <div class="pd-metric__track">
                                <div class="pd-metric__bar-bg">
                                    <div class="pd-metric__bar-fill" style="width: @(progreso)%">
                                        <span class="pd-metric__bar-text">@(progreso)% COMPLETADO</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pd-metric">
                            <div class="pd-metric__header">
                                <span class="pd-metric__label">Donaciones Recibidas</span>
                                <span class="pd-metric__achievement">@Caso.Donaciones?.Count() donantes activos</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Lista de Donantes (Opcional, similar a Metrics) -->
                @if (Caso.Donaciones != null && Caso.Donaciones.Any())
                {
                    <section class="pd-section">
                        <h3 class="pd-section__subheading">Donaciones Recientes</h3>
                        <div class="bulma-table-container">
                            <table class="bulma-table bulma-is-fullwidth bulma-is-striped">
                                <thead>
                                    <tr>
                                        <th>Donante</th>
                                        <th>Monto</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var donacion in Caso.Donaciones.OrderByDescending(d => d.FechaDonacion).Take(5))
                                    {
                                        <tr>
                                            <td>@(donacion.IdDonadorNavigation?.Nombre ?? "Anónimo")</td>
                                            <td>@donacion.Monto.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</td>
                                            <td>@donacion.FechaDonacion.ToString("d")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }

            </div><!-- /pd-body__main -->

            <!-- ── RIGHT SIDEBAR ── -->
            <aside class="pd-body__sidebar">
                <div class="pd-support-card">
                    <h3 class="pd-support-card__title">Apoya este Caso</h3>
                    <p class="pd-support-card__desc">
                        Tu donación llega directamente al beneficiario para cubrir las necesidades descritas en este caso.
                    </p>
                    <a href="/donate/case/@Caso.Id"
                       class="bulma-button bulma-is-warning bulma-is-fullwidth pd-support-card__btn">
                        <strong>Dona a este Caso</strong>
                    </a>
                </div>
            </aside>

        </div><!-- /pd-body -->
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Caso? Caso { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Caso = await CasoService.ObtenerPorIdConDetallesAsync(Id);
    }

    private int CalcularPorcentaje(decimal meta, decimal actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((actual / meta) * 100), 0, 100);
    }
}
