@page "/cases/{Id:int}"
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using System.Globalization
@inject ICasoService CasoService

@if (Caso == null)
{
    <div class="bulma-container">
        <p>Cargando detalles del caso...</p>
    </div>
}
else
{
    <div class="cd-page">
        <div class="cd-layout">
            
            <!-- ── COLUMNA PRINCIPAL ── -->
            <main class="cd-main">
                
                <!-- Hero Card (Imagen e Identidad) -->
                <article class="cd-hero-card">
                    <div class="cd-hero-card__image-wrap">
                        @if (!string.IsNullOrEmpty(Caso.ImagenUrl))
                        {
                            <img class="cd-hero-card__image" src="@Caso.ImagenUrl" alt="@Caso.Titulo" />
                        }
                        else
                        {
                            <img class="cd-hero-card__image" src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1200&q=80" alt="Placeholder" />
                        }
                        <div class="cd-hero-card__overlay"></div>
                        <div class="cd-hero-card__identity">
                            <img class="cd-hero-card__avatar" src="@(Caso.IdBeneficiadoNavigation?.ImagenPerfil ?? "wwwroot/uploads/profiles/DefaultProfile.png")" alt="Avatar" />
                            <div class="cd-hero-card__id-text">
                                <h1 class="cd-hero-card__name">@Caso.Titulo</h1>
                                <span class="cd-hero-card__location">
                                    <i class="fas fa-location-dot"></i> @(Caso.IdBeneficiadoNavigation?.Nombre) @(Caso.IdBeneficiadoNavigation?.Apellido)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-hero-card__body">
                        <div class="cd-tags">
                            <span class="cd-tag cd-tag--verified">
                                <i class="fas fa-check-circle"></i> CASO VERIFICADO
                            </span>
                            <span class="cd-tag">@Caso.IdCategoriaNavigation?.Nombre.ToUpper()</span>
                            <span class="cd-tag">@Caso.Estado.ToUpper()</span>
                        </div>
                        <div class="cd-impact">
                            <h2 class="cd-impact__title">Resumen del Impacto</h2>
                            <p class="cd-impact__quote">
                                Este caso busca proporcionar apoyo directo para cubrir necesidades de @Caso.IdCategoriaNavigation?.Nombre.
                            </p>
                        </div>
                    </div>
                </article>

                <!-- Story Card (Descripción) -->
                <section class="cd-story-card">
                    <h3 class="cd-story-card__title">
                        <i class="fas fa-book-open cd-story-card__title-icon"></i>
                        Historia del Caso
                    </h3>
                    <div class="cd-story-card__body">
                        <p>@Caso.Descripcion</p>
                    </div>
                </section>

                <!-- Metrics Card (Progreso) -->
                @{
                    decimal totalRecaudado = Caso.Donaciones?.Sum(d => d.Monto) ?? 0m;
                    int progreso = CalcularPorcentaje(Caso.Meta, totalRecaudado);
                }
                <section class="cd-metrics-card">
                    <div class="cd-vuln">
                        <span class="cd-vuln__label">ESTADO ACTUAL</span>
                        <div class="cd-vuln__ring-wrap">
                            <svg class="cd-vuln__svg" viewBox="0 0 100 100">
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#e6e4dc" stroke-width="8" />
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#22c55e" stroke-width="8" 
                                        stroke-dasharray="@(progreso * 2.82) 282" stroke-linecap="round" transform="rotate(-90 50 50)" />
                            </svg>
                            <div class="cd-vuln__center">
                                <span class="cd-vuln__score">@progreso<span class="cd-vuln__denom">%</span></span>
                                <span class="cd-vuln__badge">RECAUDADO</span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-metric-analysis">
                        <span class="cd-metric-analysis__label">Análisis de Meta</span>
                        <div class="cd-metric-row">
                            <div class="cd-metric-row__header">
                                <span class="cd-metric-row__name">Monto Recaudado</span>
                                <span class="cd-metric-row__pct">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                            </div>
                            <div class="cd-metric-row__track">
                                <div class="cd-metric-row__fill" style="width: @progreso%"></div>
                            </div>
                        </div>
                        <div class="cd-metric-row">
                            <div class="cd-metric-row__header">
                                <span class="cd-metric-row__name">Meta Financiera</span>
                                <span class="cd-metric-row__pct">@Caso.Meta.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                            </div>
                        </div>
                    </div>
                </section>

            </main>

            <!-- ── SIDEBAR ── -->
            <aside class="cd-sidebar">
                
                <div class="cd-sidebar__funding">
                    <div class="cd-sidebar__funding-top">
                        <span class="cd-sidebar__amount">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                        <span class="cd-sidebar__goal">de @Caso.Meta.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                    </div>
                    <div class="cd-sidebar__progress-track">
                        <div class="cd-sidebar__progress-fill" style="width: @progreso%"></div>
                    </div>
                    <div class="cd-sidebar__funding-meta">
                        <span class="cd-sidebar__funded-pct">@progreso% COMPLETADO</span>
                        <span class="cd-sidebar__days-left">@Caso.Donaciones?.Count() DONANTES</span>
                    </div>
                    
                    <a href="/donate/case/@Caso.Id" class="bulma-button bulma-is-warning bulma-is-fullwidth cd-sidebar__btn-support">
                        <i class="fas fa-heart"></i>
                        <strong>Donar Ahora</strong>
                    </a>
                </div>

                <div class="cd-sidebar__trust">
                    <div class="cd-sidebar__trust-item">
                        <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--green">
                            <i class="fas fa-shield-heart"></i>
                        </div>
                        <div>
                            <h4 class="cd-sidebar__trust-title">Donación Segura</h4>
                            <p class="cd-sidebar__trust-desc">Tu aporte llega íntegramente al beneficiario verificado.</p>
                        </div>
                    </div>
                    <div class="cd-sidebar__trust-item">
                        <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--yellow">
                            <i class="fas fa-file-invoice-dollar"></i>
                        </div>
                        <div>
                            <h4 class="cd-sidebar__trust-title">Transparencia Total</h4>
                            <p class="cd-sidebar__trust-desc">Recibe reportes sobre el uso de los fondos.</p>
                        </div>
                    </div>
                </div>

                @* <div class="cd-sidebar__verification">
                    <span class="cd-sidebar__verification-label">
                        <i class="fas fa-user-shield"></i> VERIFICACIÓN AGENTES
                    </span>
                    <p class="cd-sidebar__verification-desc">Este caso ha sido auditado por nuestro equipo de campo.</p>
                    <div class="cd-sidebar__agents">
                        <div class="cd-sidebar__agents-avatars">
                            <img class="cd-sidebar__agent-avatar" src="https://i.pravatar.cc/150?u=1" alt="A1" />
                            <img class="cd-sidebar__agent-avatar cd-sidebar__agent-avatar--offset" src="https://i.pravatar.cc/150?u=2" alt="A2" />
                        </div>
                        <span class="cd-sidebar__agents-label">2 Agentes Asignados</span>
                    </div>
                </div> *@

            </aside>

        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Caso? Caso { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Caso = await CasoService.ObtenerPorIdConDetallesAsync(Id);
    }

    private int CalcularPorcentaje(decimal meta, decimal actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((actual / meta) * 100), 0, 100);
    }
}
