@page "/registrarse/step2"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProyectoSocioEconomico.WebUI.Services.RegistrationState RegState
@using ProyectoSocioEconomico.WebUI.Services
@inject CustomAuthenticationStateProvider AuthStateProvider

<div class="register-page">

    @* ─────────────── MAIN CONTENT ─────────────── *@
    <main class="register-page__main">
        <div class="register-page__card">

            <!-- PROGRESS (Same as Step 1) -->
            <div class="register-page__progress-section">
                <div class="register-page__progress-header">
                    <span class="register-page__step-label">Paso 2 de 3</span>
                </div>
                <progress class="register-page__progress-bar bulma-progress bulma-is-success" value="66"
                          max="100">66%</progress>
            </div>

            <!-- HEADING -->
            <div class="register-page__heading-block">
                <h1 class="register-page__title">Documentación Legal</h1>
                <p class="register-page__subtitle">
                    Por favor, proporciona tu documentación legal para el análisis socioeconómico.
                    Esta información se maneja de forma segura y encriptada.
                </p>
            </div>

            <!-- FORM FIELDS -->
            <div class="register-page__form">

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="bulma-notification bulma-is-danger bulma-is-light bulma-py-2 bulma-px-3 bulma-mb-4" style="font-size: 0.9rem;">
                        <i class="fa-solid fa-circle-exclamation bulma-mr-2"></i> @mensajeError
                    </div>
                }

                <!-- DUI Number -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Número de DUI</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <input class="register-page__input bulma-input @(mostrarErrores && !EsDuiValido(RegState.DuiNumber) ? "bulma-is-danger" : "")" 
                               type="text"
                               placeholder="00000000-0" 
                               maxlength="10" 
                               @bind="RegState.DuiNumber"
                               @bind:event="oninput" />
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2" />
                                <circle cx="9" cy="10" r="2" />
                                <line x1="15" y1="8" x2="19" y2="8" />
                                <line x1="15" y1="12" x2="19" y2="12" />
                                <line x1="15" y1="16" x2="19" y2="16" />
                            </svg>
                        </span>
                    </div>
                    @if (mostrarErrores && !EsDuiValido(RegState.DuiNumber))
                    {
                        <p class="bulma-help bulma-is-danger">El DUI debe tener el formato 00000000-0</p>
                    }
                </div>

                <!-- Date of Birth -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Fecha de Nacimiento</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <input class="register-page__input bulma-input @(mostrarErrores && !EsFechaValida(RegState.BirthDate) ? "bulma-is-danger" : "")" 
                               type="date" 
                               @bind="RegState.BirthDate" />
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                        </span>
                    </div>
                    @if (mostrarErrores && !EsFechaValida(RegState.BirthDate))
                    {
                        <p class="bulma-help bulma-is-danger">Debes ser mayor de 18 años.</p>
                    }
                </div>

                <!-- DUI Photo Upload -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Subir fotos de DUI (Frente y Reverso)</label>
                    <div class="columns is-mobile is-variable is-2">
                        <div class="column">
                            <div class="dui-upload-box @(RegState.DuiFrontData != null ? "has-file" : (mostrarErrores ? "has-error" : ""))">
                                <label class="upload-label">
                                    <InputFile OnChange="HandleFrontChange" accept="image/png, image/jpeg, image/jpg, image/webp" />
                                    <i class="fas @(RegState.DuiFrontData != null ? "fa-check-circle" : "fa-camera")"></i>
                                    <span>@(RegState.DuiFrontData != null ? "Cargado" : "Frente")</span>
                                </label>
                            </div>
                        </div>
                        <div class="column">
                            <div class="dui-upload-box @(RegState.DuiBackData != null ? "has-file" : (mostrarErrores ? "has-error" : ""))">
                                <label class="upload-label">
                                    <InputFile OnChange="HandleBackChange" accept="image/png, image/jpeg, image/jpg, image/webp" />
                                    <i class="fas @(RegState.DuiBackData != null ? "fa-check-circle" : "fa-camera")"></i>
                                    <span>@(RegState.DuiBackData != null ? "Cargado" : "Reverso")</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    @if (mostrarErrores && (RegState.DuiFrontData == null || RegState.DuiBackData == null))
                    {
                        <p class="bulma-help bulma-is-danger">Es obligatorio subir ambas fotografías.</p>
                    }
                    <p class="bulma-help bulma-has-text-grey">Formatos permitidos: JPG, PNG, WEBP.</p>
                </div>

                <!-- Navigation -->
                <div class="register-page__nav-buttons">
                    <button class="bulma-button bulma-is-ghost" @onclick="GoBack">
                         Atrás
                    </button>
                    <button class="bulma-button bulma-is-warning bulma-has-text-weight-bold" @onclick="GoToStep3">
                        Siguiente Paso
                        <span class="register-page__btn-arrow">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12" />
                                <polyline points="12 5 19 12 12 19" />
                            </svg>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        if (!RegState.Step1Completed)
        {
            Navigation.NavigateTo("/");
        }
    }

    private string mensajeError = string.Empty;
    private bool mostrarErrores = false;

    private bool EsDuiValido(string dui)
    {
        if (string.IsNullOrWhiteSpace(dui)) return false;
        // Formato esperado: 00000000-0 (8 dígitos, guion, 1 dígito)
        return System.Text.RegularExpressions.Regex.IsMatch(dui, @"^\d{8}-\d{1}$");
    }

    private bool EsFechaValida(DateTime? date)
    {
        if (!date.HasValue) return false;
        // Validación básica: mayor de 18 años
        return date.Value <= DateTime.Today.AddYears(-18);
    }

    private async Task HandleFrontChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            RegState.DuiFrontData = ms.ToArray();
            RegState.DuiFrontName = file.Name;
        }
        StateHasChanged();
    }

    private async Task HandleBackChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            RegState.DuiBackData = ms.ToArray();
            RegState.DuiBackName = file.Name;
        }
        StateHasChanged();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/registrarse");
    }

    private void GoToStep3()
    {
        mensajeError = string.Empty;
        mostrarErrores = true;

        if (!EsDuiValido(RegState.DuiNumber))
        {
            mensajeError = "Por favor, ingresa un número de DUI válido (00000000-0).";
            return;
        }

        if (!EsFechaValida(RegState.BirthDate))
        {
            mensajeError = "Por favor, ingresa una fecha de nacimiento válida (debes ser mayor de 18 años).";
            return;
        }

        if (RegState.DuiFrontData == null || RegState.DuiBackData == null)
        {
            mensajeError = "Por favor, sube ambas fotos de tu DUI (frente y reverso).";
            return;
        }

        RegState.Step2Completed = true;
        Navigation.NavigateTo("/registrarse/step3");
    }
}
