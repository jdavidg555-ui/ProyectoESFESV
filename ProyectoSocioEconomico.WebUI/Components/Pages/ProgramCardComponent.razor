@*
  ProgramCardComponent.razor
  Propósito: Componente para mostrar un programa (similar a CaseCardComponent) con etiqueta
  de categoría, progreso y enlace a detalles del programa.
*@
@using ProyectoSocioEconomico.Domain.Entities

<article class="cap-card @(Compact ? "cap-card--compact" : string.Empty)">
    <div class="cap-card__image-wrap">
        @if (!string.IsNullOrEmpty(ImageUrl))
        {
            <img class="cap-card__image" src="@ImageUrl" alt="@Title" />
        }
        else
        {
            <img class="cap-card__image" src="https://bulma.io/assets/images/placeholders/1280x960.png" alt="Placeholder" />
        }
        
        <span class="cap-card__tag @GetCategoryClass(Category)">
            @Category?.ToUpper()
        </span>
    </div>

    <div class="cap-card__body">
        <h2 class="cap-card__title">@Title</h2>
        <p class="cap-card__desc">@Description</p>

        <div class="cap-card__progress-block">
            <div class="cap-card__progress-header">
                <span class="cap-card__progress-label">@ProgressLabel</span>
                <span class="cap-card__progress-pct">@Progress%</span>
            </div>
            <progress class="bulma-progress bulma-is-success cap-card__progress-bar"
                      value="@Progress" max="100">
                @Progress%
            </progress>
        </div>

        <a href="/programs/@Id" class="bulma-button bulma-is-warning bulma-is-fullwidth cap-card__btn">
            <strong>View Program Details</strong>
        </a>
    </div>
</article>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Category { get; set; } = string.Empty;
    [Parameter] public string ProgressLabel { get; set; } = "Progress";
    [Parameter] public int Progress { get; set; }
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public bool Compact { get; set; }

    private static string GetCategoryClass(string? categoryName)
    {
        if (string.IsNullOrWhiteSpace(categoryName))
        {
            return string.Empty;
        }

        var normalized = categoryName.ToLowerInvariant();

        if (normalized.Contains("salud"))
        {
            return "cap-card__tag--health";
        }

        if (normalized.Contains("educacion") || normalized.Contains("educación"))
        {
            return "cap-card__tag--education";
        }

        if (normalized.Contains("infraestructura"))
        {
            return "cap-card__tag--infrastructure";
        }

        if (normalized.Contains("naturaleza"))
        {
            return "cap-card__tag--environment";
        }

        if (normalized.Contains("desastres"))
        {
            return "cap-card__tag--disaster";
        }

        return string.Empty;
    }
}
