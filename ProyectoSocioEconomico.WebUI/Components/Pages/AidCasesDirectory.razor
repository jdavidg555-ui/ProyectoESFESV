@page "/cases"

<div class="ic-page">

    <!-- ═══════════════ PAGE HEADER ═══════════════ -->
    <div class="ic-header">
        <h1 class="ic-header__title">Directory of Individual Aid Cases</h1>
        <p class="ic-header__subtitle">
            Visualizing socioeconomic priority for verified families and individuals.<br />
            Currently showing <strong>4,208</strong> active cases awaiting intervention.
        </p>
    </div>

    <!-- ═══════════════ CASES GRID ═══════════════ -->
    <div class="ic-grid">
        @foreach (var c in Cases)
        {
            <article class="ic-card @(c.Priority.HasValue ? "ic-card--has-priority" : "")">

                @if (c.Priority.HasValue)
                {
                    <div class="ic-card__priority-badge">
                        <span class="ic-card__priority-label">Priority:</span>
                        <span class="ic-card__priority-value">@c.Priority/100</span>
                    </div>
                }

                <!-- Identity row -->
                <div class="ic-card__identity">
                    <img class="ic-card__avatar" src="@c.AvatarUrl" alt="@c.Name" />
                    <div class="ic-card__id-text">
                        <h2 class="ic-card__name">@c.Name</h2>
                        <span class="ic-card__sector ic-card__sector--@c.SectorClass">
                            @c.Sector<br />SECTOR
                        </span>
                    </div>
                </div>

                <!-- Description -->
                <p class="ic-card__desc">@c.Description</p>

                <!-- Goal + progress -->
                <div class="ic-card__goal-wrap">
                    <div class="ic-card__goal-header">
                        <span class="ic-card__goal-label">Goal: @c.GoalLabel</span>
                        @if (c.Priority.HasValue)
                        {
                            <span class="ic-card__goal-pct">@c.FundingPct%</span>
                        }
                    </div>
                    <div class="ic-card__progress-track">
                        <div class="ic-card__progress-fill" style="width: @(c.FundingPct)%"></div>
                    </div>
                </div>

                <!-- CTA -->
                <a href="/cases/@c.Id" class="bulma-button bulma-is-warning bulma-is-fullwidth ic-card__btn">
                    <span class="bulma-icon bulma-is-small"><i class="fas fa-hand-holding-heart"></i></span>
                    <strong>@(c.Priority.HasValue ? "Help this Case" : "Help this")</strong>
                </a>

            </article>
        }
    </div>

</div>

@code {
    private record CaseItem(
        int     Id,
        string  Name,
        string  Sector,
        string  SectorClass,
        string  Description,
        string  GoalLabel,
        int     FundingPct,
        string  AvatarUrl,
        int?    Priority = null
    );

    private List<CaseItem> Cases = new()
    {
        new(1,  "Sarah Jenkins",
            "HEALTH",     "health",
