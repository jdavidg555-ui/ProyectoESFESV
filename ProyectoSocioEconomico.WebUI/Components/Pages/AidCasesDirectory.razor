@page "/cases"
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using System.Globalization
@inject ICasoService CasoService

<div class="cap-page">

    <!-- ═══════════════ HEADER ═══════════════ -->
    <div class="cap-header">
        <h1 class="cap-header__title">Direct Aid Cases</h1>
        <p class="cap-header__subtitle">
            Support individual cases and families in need. Your direct contribution makes a tangible difference
            in someone's life today.
        </p>
    </div>

    <!-- ═══════════════ SEARCH + FILTERS ═══════════════ -->
    <div class="cap-toolbar">
        <div class="bulma-control bulma-has-icons-left cap-toolbar__search-wrap">
            <input class="bulma-input cap-toolbar__search"
                   type="text"
                   placeholder="Search for cases (e.g., 'Emergency Medical')"
                   @bind="SearchQuery"
                   @oninput="OnSearch" />
            <span class="bulma-icon bulma-is-left cap-toolbar__search-icon">
                <i class="fas fa-magnifying-glass"></i>
            </span>
        </div>

        <div class="cap-toolbar__filters">
            @foreach (var filter in Filters)
            {
                <button class="cap-filter-btn @(ActiveFilter == filter.Key ? "cap-filter-btn--active" : "")"
                        @onclick="() => SetFilter(filter.Key)">
                    <span class="bulma-icon bulma-is-small">
                        <i class="@filter.Icon"></i>
                    </span>
                    @filter.Label
                </button>
            }
        </div>
    </div>

    <!-- ═══════════════ CASE GRID ═══════════════ -->
    <div class="cap-grid">
        @if (PagedCases != null)
        {
            @foreach (var caso in PagedCases)
            {
                decimal totalRecaudado = caso.Donaciones?.Sum(d => d.Monto) ?? 0m;
                int progreso = CalcularPorcentaje(caso.Meta, totalRecaudado);

                <CaseCardComponent Id="@caso.Id"
                                   Title="@caso.Titulo"
                                   Description="@caso.Descripcion"
                                   Category="@caso.IdCategoriaNavigation?.Nombre"
                                   MoneyRaised="@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))"
                                   Progress="@progreso"
                                   ImageUrl="@caso.ImagenUrl" />
            }
        }
    </div>

    <!-- ═══════════════ PAGINATION ═══════════════ -->
    <nav class="cap-pagination" aria-label="pagination">
        <button class="cap-pagination__btn"
                disabled="@(CurrentPage == 1)"
                @onclick="() => GoToPage(CurrentPage - 1)">
            Previous
        </button>

        @for (int p = 1; p <= TotalPages; p++)
        {
            int pageNumber = p;
            <button class="cap-pagination__btn @(CurrentPage == pageNumber ? "cap-pagination__btn--active" : "")"
                    @onclick="() => GoToPage(pageNumber)">
                @pageNumber
            </button>
        }

        <button class="cap-pagination__btn"
                disabled="@(CurrentPage == TotalPages)"
                @onclick="() => GoToPage(CurrentPage + 1)">
            Next
        </button>
    </nav>

</div>

@code {
    private record FilterOption(string Key, string Label, string Icon);

    private string SearchQuery  { get; set; } = string.Empty;
    private string ActiveFilter { get; set; } = "all";
    private int    CurrentPage  { get; set; } = 1;
    private const int PageSize  = 6;

    private List<FilterOption> Filters = new()
    {
        new("all",            "All",            "fas fa-table-cells-large"),
        new("salud",          "Salud",          "fas fa-heart-pulse"),
        new("educación",      "Educación",      "fas fa-graduation-cap"),
        new("vivienda",       "Vivienda",       "fas fa-house-user"),
        new("emergencia",     "Emergencia",     "fas fa-kit-medical"),
        new("otros",          "Otros",          "fas fa-ellipsis-h"),
    };

    private List<Caso> AllCases = new();

    protected override async Task OnInitializedAsync()
    {
        AllCases = await CasoService.ObtenerTodosConDetallesAsync();
    }

    private IEnumerable<Caso> FilteredCases =>
        AllCases
            .Where(c => ActiveFilter == "all" || c.IdCategoriaNavigation?.Nombre.ToLower() == ActiveFilter)
            .Where(c => string.IsNullOrWhiteSpace(SearchQuery) ||
                        c.Titulo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                        c.Descripcion.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredCases.Count() / PageSize));

    private IEnumerable<Caso> PagedCases =>
        FilteredCases.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private void SetFilter(string key)
    {
        ActiveFilter = key;
        CurrentPage  = 1;
    }

    private void OnSearch(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
            CurrentPage = page;
    }

    private int CalcularPorcentaje(decimal meta, decimal actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((actual / meta) * 100), 0, 100);
    }
}
