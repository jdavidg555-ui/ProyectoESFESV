@namespace ProyectoSocioEconomico.WebUI.Components.Pages
@*
  Step2.razor
  Propósito: Segundo paso del flujo de registro. Recoge documentos y archivos de respaldo
  (evidencias) y permite cargar una miniatura para la cuenta.
*@
@page "/registrarse/step2"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProyectoSocioEconomico.WebUI.Services.RegistrationState RegState
@using ProyectoSocioEconomico.WebUI.Services
@inject CustomAuthenticationStateProvider AuthStateProvider

<div class="register-page">

    @* ─────────────── MAIN CONTENT ─────────────── *@
    <main class="register-page__main">
        <div class="register-page__card">

            <!-- PROGRESS (Same as Step 1) -->
            <div class="register-page__progress-section">
                <div class="register-page__progress-header">
                    <span class="register-page__step-label">Paso 2 de 3</span>
                </div>
                <progress class="register-page__progress-bar bulma-progress bulma-is-success" value="66"
                          max="100">66%</progress>
            </div>

            <!-- HEADING -->
            <div class="register-page__heading-block">
                <h1 class="register-page__title">Documentación Legal</h1>
                <p class="register-page__subtitle">
                    Por favor, proporciona tu documentación legal para el análisis socioeconómico.
                    Esta información se maneja de forma segura y encriptada.
                </p>
            </div>

            <!-- FORM FIELDS -->
            <div class="register-page__form">

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="bulma-notification bulma-is-danger bulma-is-light bulma-py-2 bulma-px-3 bulma-mb-4" style="font-size: 0.9rem;">
                        <i class="fa-solid fa-circle-exclamation bulma-mr-2"></i> @mensajeError
                    </div>
                }

                <!-- DUI Number -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Número de DUI</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <input class="register-page__input bulma-input @(mostrarErrores && !EsDuiValido(RegState.DuiNumber) ? "bulma-is-danger" : "")" 
                               type="text"
                               placeholder="00000000-0" 
                               maxlength="10" 
                               @bind="RegState.DuiNumber"
                               @bind:event="oninput" />
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2" />
                                <circle cx="9" cy="10" r="2" />
                                <line x1="15" y1="8" x2="19" y2="8" />
                                <line x1="15" y1="12" x2="19" y2="12" />
                                <line x1="15" y1="16" x2="19" y2="16" />
                            </svg>
                        </span>
                    </div>
                    @if (mostrarErrores && !EsDuiValido(RegState.DuiNumber))
                    {
                        <p class="bulma-help bulma-is-danger">El DUI debe tener el formato 00000000-0</p>
                    }
                </div>

                <!-- Date of Birth -->
                <div class="register-page__field bulma-field">
                    <label class="register-page__label bulma-label">Fecha de Nacimiento</label>
                    <div class="register-page__control bulma-control bulma-has-icons-left">
                        <input class="register-page__input bulma-input @(mostrarErrores && !EsFechaValida(RegState.BirthDate) ? "bulma-is-danger" : "")" 
                               type="date" 
                               @bind="RegState.BirthDate" />
                        <span class="register-page__icon bulma-icon bulma-is-left">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                            </svg>
                        </span>
                    </div>
                    @if (mostrarErrores && !EsFechaValida(RegState.BirthDate))
                    {
                        <p class="bulma-help bulma-is-danger">Por favor, ingresa una fecha válida.</p>
                    }
                </div>

                <!-- NAV BUTTONS -->
                <div class="register-page__nav-buttons">
                    <button class="bulma-button bulma-is-ghost" @onclick='() => Navigation.NavigateTo("/")'>Cancelar</button>
                    <button class="bulma-button bulma-is-warning" @onclick="GoToStep3">Siguiente</button>
                </div>

            </div> <!-- /register-page__form -->
        </div>
    </main>
</div>

@code {
    private string mensajeError = string.Empty;
    private bool mostrarErrores = false;

    private bool EsDuiValido(string? dui) => !string.IsNullOrWhiteSpace(dui) && dui.Length >= 10;
    private bool EsFechaValida(DateTime? d) => d.HasValue;

    private void GoToStep3()
    {
        mostrarErrores = true;
        if (!EsDuiValido(RegState.DuiNumber) || !EsFechaValida(RegState.BirthDate))
        {
            mensajeError = "Por favor completa los datos requeridos.";
            return;
        }

        RegState.Step2Completed = true;
        Navigation.NavigateTo("/registrarse/step3");
    }
}
